{trigger:kw_fernlicht_toggle}
	(L.L.lights_sw_fern) ! (S.L.lights_sw_fern)

	(T.L.ev_wischerhebel)
{end}

{trigger:light_dim}
	(L.L.Licht_vorne_aus) ! (S.L.Licht_vorne_aus)

	(L.L.Licht_vorne_aus) (S.L.light_dim_anim)

	(L.L.Licht_vorne_aus) 1 =
	{if}
		(T.L.ev_VDV_on)
	{else}
		(T.L.ev_VDV_off)
	{endif}
{end}



{trigger:kw_fernlicht_toggle_off}
	(L.L.light_mode) 1 <=
	{if}
		0 (S.L.lights_sw_fern)
		(T.L.ev_wischerhebel)
	{endif}
{end}

{trigger:kw_scheinwerfer_toggle}

	(L.L.light_mode) 0 =
	{if}
	1 (S.L.light_mode)
	(T.L.ev_licht_dreh)
	{else}
	(L.L.light_mode) 1 =
	{if}
	2 (S.L.light_mode)
	(T.L.ev_licht_dreh)
	{else}
	0 (S.L.light_mode)
	(T.L.ev_licht_dreh)
	{endif}
	{endif}


{end}

{trigger:kw_scheinwerfer_toggle_manuell}

	(L.L.light_mode) 0 =
	{if}
	1 (S.L.light_mode)
	(T.L.ev_licht_dreh)
	{else}
	(L.L.light_mode) 1 =
	{if}
	2 (S.L.light_mode)
	(T.L.ev_licht_dreh)
	{else}
	(L.L.light_mode) 2 =
	{if}
	3 (S.L.light_mode)
	(T.L.ev_licht_zieh)
	{else}
	(L.L.light_mode) 3 =
	{if}
	4 (S.L.light_mode)
	(T.L.ev_licht_zieh)
	{else}
	0 (S.L.light_mode)
	(T.L.ev_licht_dreh)
	(T.L.ev_licht_zieh)
	{endif}
	{endif}
	{endif}
	{endif}


{end}

{trigger:kw_standlicht_toggle}
	(L.L.light_mode) 1 =
	{if}
		0 (S.L.light_mode)
	{else}
		1 (S.L.light_mode)
	{endif}
	(T.L.ev_licht_dreh)
{end}

{trigger:blinker_off}
	(L.L.lights_sw_blinker) 0 >
	{if}
			(T.L.ev_lights_blinker_swoff)
			0 (S.L.lights_sw_blinker) 
	{endif}
{end}

{trigger:blinker_left_move}
	(L.L.lights_sw_blinker)
	0 =
	{if}
		1 (S.L.lights_sw_blinker)
		(T.L.ev_lights_blinker_swon)
		(M.L.lights_calc_geberfaktor)
		(M.L.lights_startblinkgeber)
	{else}
		(T.L.ev_lights_blinker_swoff)
		0 (S.L.lights_sw_blinker) 
	{endif}
{end}


{trigger:blinker_right_move}
	(L.L.lights_sw_blinker)
	0 =
	{if}
		2 (S.L.lights_sw_blinker)
		(T.L.ev_lights_blinker_swon)
		(M.L.lights_calc_geberfaktor)
		(M.L.lights_startblinkgeber)
	{else}
		(T.L.ev_lights_blinker_swoff)
		0 (S.L.lights_sw_blinker)  
	{endif}
{end}

{trigger:blinker_left_set}
	(L.L.lights_sw_blinker) 1 = !
	{if}
		(T.L.ev_lights_blinker_swon)
	{endif}
	1 (S.L.lights_sw_blinker)
	(M.L.lights_calc_geberfaktor)
	(M.L.lights_startblinkgeber)
{end}

{trigger:blinker_right_set}
	(L.L.lights_sw_blinker) 2 = !
	{if}
		(T.L.ev_lights_blinker_swon)
	{endif}
	2 (S.L.lights_sw_blinker)
	(M.L.lights_calc_geberfaktor)
	(M.L.lights_startblinkgeber)
{end}


{macro:lights_frame}

(L.L.door1_close_indicator) (S.L.lights_door1_warn)
(L.L.door2_close_indicator) (S.L.lights_door2_warn)
(L.L.door3_close_indicator) (S.L.lights_door3_warn)
(L.L.door4_close_indicator) (S.L.lights_door4_warn)

(L.L.lights_stand)
{if}
	(L.L.Front_Stadt_UE)
	{if}
	0 (S.L.lights_Posi_Stadt)
	1 (S.L.lights_Posi_UE)
	{else}
	0 (S.L.lights_Posi_UE)
	1 (S.L.lights_Posi_Stadt)
	{endif}
{else}
0 (S.L.lights_Posi_Stadt) (S.L.lights_Posi_UE)
{endif}

(L.L.lights_sw_warnblinker)
(L.L.lights_blinkgeber) &&
{if}
1 (S.L.warnblinker_step3)
{else}
0 (S.L.warnblinker_step3)
{endif}

' alte decke
(L.L.neue_Decke) 0 =
{if}
	(L.L.engine_on)
	{if}
		(L.L.lights_beleuchtung_vorne_Tuer) 1 =
		{if}
		1 (S.L.Alte_Decke_Licht_Modus)
		{else}
		2 (S.L.Alte_Decke_Licht_Modus)
		{endif}
	{else}
	3 (S.L.Alte_Decke_Licht_Modus)
	{endif}
{else}
0 (S.L.Alte_Decke_Licht_Modus)
{endif}

' Tuerschliess lampe

(L.L.doorwarn_req01) 0 >
{if}
	0 (S.L.doorwarn_req01)
	1.75 (S.L.doorwarn_timer01)

	(L.L.elec_busbar_main)
	{if}
		1 (S.L.door1_close_indicator)
		0 (S.L.lights_door1)
		1 (S.L.lights_door1_warn)

		0.505 (S.L.door_1_blinkgeber_timegap)

		1 (S.L.door_1_blinkgeber)
		1 (S.L.door_1_blinker_running)
		0 (S.L.door_1_blinker_runtime)
	{endif}
{endif}

(L.L.doorwarn_timer01) 0 >
(L.L.elec_busbar_main) &&
{if}
	(L.L.doorwarn_timer01) (L.S.Timegap) - 0 max (S.L.doorwarn_timer01)

	(L.S.Timegap) (L.L.door_1_blinker_runtime) + (S.L.door_1_blinker_runtime)
	(L.L.door_1_blinker_runtime) (L.L.door_1_blinkgeber_timegap) >
	{if}
		(L.L.door_1_blinkgeber) ! (S.L.door_1_blinkgeber)
		{if}
			1 (S.L.door1_close_indicator)
			1 (S.L.lights_door1_warn)
			0 (S.L.lights_door1)
			0.460
		{else}
			0 (S.L.door1_close_indicator)
			0 (S.L.lights_door1_warn)
			0 (S.L.lights_door1)
			0.637
		{endif}
		(S.L.door_1_blinkgeber_timegap)
		0 (S.L.door_1_blinker_runtime)
	{endif}
{else}
	0 (S.L.door1_close_indicator)
	0 (S.L.door_1_blinkgeber) (S.L.door_1_blinker_runtime) (S.L.door_1_blinker_running)
	0 (S.L.doorwarn_timer01)
	0 (S.L.lights_door1_warn)
{endif}

(L.L.doorwarn_req23) 0 >
{if}
	0 (S.L.doorwarn_req23)
	1.75 (S.L.doorwarn_timer23)

	(L.L.elec_busbar_main)
	{if}
		1 (S.L.door2_close_indicator)
		0 (S.L.lights_door2)
		1 (S.L.lights_door2_warn) 

		0.505 (S.L.door_2_blinkgeber_timegap)

		1 (S.L.door_2_blinkgeber)
		1 (S.L.door_2_blinker_running)
		0 (S.L.door_2_blinker_runtime)
	{endif}
{endif}

(L.L.doorwarn_timer23) 0 >
(L.L.elec_busbar_main) &&
{if}
	(L.L.doorwarn_timer23) (L.S.Timegap) - 0 max (S.L.doorwarn_timer23)

	(L.S.Timegap) (L.L.door_2_blinker_runtime) + (S.L.door_2_blinker_runtime)
	(L.L.door_2_blinker_runtime) (L.L.door_2_blinkgeber_timegap) >
	{if}
		(L.L.door_2_blinkgeber) ! (S.L.door_2_blinkgeber)
		{if}
			1 (S.L.door2_close_indicator)
			1 (S.L.lights_door2_warn)
			0 (S.L.lights_door2)
			0.460
		{else}
			0 (S.L.door2_close_indicator)
			0 (S.L.lights_door2_warn)
			0 (S.L.lights_door2)
			0.637
		{endif}
		(S.L.door_2_blinkgeber_timegap)
		0 (S.L.door_2_blinker_runtime)
	{endif}
{else}
	0 (S.L.door2_close_indicator)
	0 (S.L.door_2_blinkgeber) (S.L.door_2_blinker_runtime) (S.L.door_2_blinker_running)
	0 (S.L.doorwarn_timer23)
	0 (S.L.lights_door2_warn)
{endif}



(L.L.doorwarn_req45) 0 >
{if}
	0 (S.L.doorwarn_req45)
	1.75 (S.L.doorwarn_timer45)

	(L.L.elec_busbar_main)
	{if}
		1 (S.L.door3_close_indicator)
		0 (S.L.lights_door3)
		1 (S.L.lights_door3_warn)

		0.505 (S.L.door_3_blinkgeber_timegap)

		1 (S.L.door_3_blinkgeber)
		1 (S.L.door_3_blinker_running)
		0 (S.L.door_3_blinker_runtime)
	{endif}
{endif}

(L.L.doorwarn_timer45) 0 >
(L.L.elec_busbar_main) &&
{if}
	(L.L.doorwarn_timer45) (L.S.Timegap) - 0 max (S.L.doorwarn_timer45)

	(L.S.Timegap) (L.L.door_3_blinker_runtime) + (S.L.door_3_blinker_runtime)
	(L.L.door_3_blinker_runtime) (L.L.door_3_blinkgeber_timegap) >
	{if}
		(L.L.door_3_blinkgeber) ! (S.L.door_3_blinkgeber)
		{if}
			1 (S.L.door3_close_indicator)
			1 (S.L.lights_door3_warn)
			0 (S.L.lights_door3)
			0.460
		{else}
			0 (S.L.door3_close_indicator)
			0 (S.L.lights_door3_warn)
			0 (S.L.lights_door3)
			0.637
		{endif}
		(S.L.door_3_blinkgeber_timegap)
		0 (S.L.door_3_blinker_runtime)
	{endif}
{else}
	0 (S.L.door3_close_indicator)
	0 (S.L.door_3_blinkgeber) (S.L.door_3_blinker_runtime) (S.L.door_3_blinker_running)
	0 (S.L.doorwarn_timer45)
	0 (S.L.lights_door3_warn)
{endif}



(L.L.doorwarn_req67) 0 >
{if}
	0 (S.L.doorwarn_req67)
	1.75 (S.L.doorwarn_timer67)

	(L.L.elec_busbar_main)
	{if}
		1 (S.L.door4_close_indicator)
		0 (S.L.lights_door4)
		1 (S.L.lights_door4_warn)

		0.505 (S.L.door_4_blinkgeber_timegap)

		1 (S.L.door_4_blinkgeber)
		1 (S.L.door_4_blinker_running)
		0 (S.L.door_4_blinker_runtime)
	{endif}
{endif}

(L.L.doorwarn_timer67) 0 >
(L.L.elec_busbar_main) &&
{if}
	(L.L.doorwarn_timer67) (L.S.Timegap) - 0 max (S.L.doorwarn_timer67)

	(L.S.Timegap) (L.L.door_4_blinker_runtime) + (S.L.door_4_blinker_runtime)
	(L.L.door_4_blinker_runtime) (L.L.door_4_blinkgeber_timegap) >
	{if}
		(L.L.door_4_blinkgeber) ! (S.L.door_4_blinkgeber)
		{if}
			1 (S.L.door4_close_indicator)
			1 (S.L.lights_door4_warn)
			0 (S.L.lights_door4)
			0.460
		{else}
			0 (S.L.door4_close_indicator)
			0 (S.L.lights_door4_warn)
			0 (S.L.lights_door4)
			0.637
		{endif}
		(S.L.door_4_blinkgeber_timegap)
		0 (S.L.door_4_blinker_runtime)
	{endif}
{else}
	0 (S.L.door4_close_indicator)
	0 (S.L.door_4_blinkgeber) (S.L.door_4_blinker_runtime) (S.L.door_4_blinker_running)
	0 (S.L.doorwarn_timer67)
	0 (S.L.lights_door4_warn)
{endif}




(L.L.light_mode) 1 =
(L.L.light_mode) 2 = ||
(L.L.light_mode) 3 = ||
(L.L.light_mode) 4 = ||
(L.L.engine_on) ||
{if}
1 (S.L.tagfahrlicht)
{else}
0 (S.L.tagfahrlicht)
{endif}


(L.L.light_mode) 2 =
(L.L.light_mode) 3 = ||
(L.L.light_mode) 4 = ||
(L.L.engine_on) &&
{if}
1 (S.L.abblendlicht_an)
{else}
0 (S.L.abblendlicht_an)
{endif}


	(M.L.lights_AI)

	(M.L.lights_calc_geberfaktor)
	(M.L.lights_runblinkgeber)

'In HH kein Bremslicht bei aktiver Haltestellenbremse
	(L.L.brake) 0.1 > (L.L.bremse_halte) (C.L.lights_brems_haltestellenbremse) && || (L.L.elec_busbar_main) sqr *
		(S.L.lights_brems)
		(S.L.lights_brems_2)
		{endif}

	(L.L.antrieb_getr_gangwahl) 0 = (L.L.elec_busbar_main) sqr *
		(S.L.lights_rueckfahr)

	(L.L.lights_sw_blinker) 1 = (L.L.lights_sw_warnblinker) || (L.L.schulfahrschaltung) || (L.L.lights_blinkgeber) && (L.L.elec_busbar_avail) sqr *
		(S.L.lights_blinker_l)

	(L.L.lights_sw_blinker) 2 = (L.L.lights_sw_warnblinker) || (L.L.schulfahrschaltung) || (L.L.lights_blinkgeber) && (L.L.elec_busbar_avail) sqr *
		(S.L.lights_blinker_r)

'MCQ: AI-Blinkererkennung:
	(L.L.AI) !
	{if}
		(L.L.lights_sw_blinker) 1 = (L.L.elec_busbar_main) sqr * (L.L.lights_sw_warnblinker) (L.L.elec_busbar_avail) sqr * max
			(S.L.AI_Blinker_L)

		(L.L.lights_sw_blinker) 2 = (L.L.elec_busbar_main) sqr * (L.L.lights_sw_warnblinker) (L.L.elec_busbar_avail) sqr * max
			(S.L.AI_Blinker_R)

		(L.L.lights_fern)
		{if}
			2
		{else}
			(L.L.lights_abbl)
			{if}
				1
			{else}
				(L.L.lights_stand)
				{if}
					0.5
				{else}
					0
				{endif}
			{endif}
		{endif}
		(S.L.AI_Light)

		(L.L.lights_beleuchtung_unterdeck) (S.L.AI_Interiorlight)

	{endif}

'Automatische Blinkerabschaltung:

	(L.L.Axle_Steering_0_L) (C.L.lights_blinkautom_minLenk) > (L.L.lights_sw_blinker) 2 = &&
	{if}
		1 (S.L.lights_blinkautom_r_armed)
	{else}
		(L.L.lights_blinkautom_r_armed)
		{if}
			(T.L.ev_lights_blinker_swoff)
			0
				(S.L.lights_sw_blinker) (S.L.lights_blinkgeber)
				(S.L.lights_blinkautom_r_armed)
		{endif}
	{endif}

	(L.L.Axle_Steering_0_L) /-/ (C.L.lights_blinkautom_minLenk) > (L.L.lights_sw_blinker) 1 = &&
	{if}
		1 (S.L.lights_blinkautom_l_armed)
	{else}
		(L.L.lights_blinkautom_l_armed)
		{if}
			(T.L.ev_lights_blinker_swoff)
			0
				(S.L.lights_sw_blinker) (S.L.lights_blinkgeber)
				(S.L.lights_blinkautom_l_armed)
		{endif}
	{endif}

'	Abschaltung Schulfahrschaltung

	(L.L.lights_sw_blinker) 1 =
	{if}
		0 (S.L.schulfahrschaltung)
	{endif}


'	Beleuchtungsfunktionen 

	(L.L.elec_busbar_avail)
	{if}
		(L.L.light_mode) 0 =
		{if}
			0
			(S.L.VDV_lightswitch_anim)
			(S.L.lights_stand)
			(S.L.lights_terminus)
			(S.L.lights_rueck)
			(S.L.lights_rueck_2)
			(S.L.lights_abbl)
			(S.L.lights_nebelschw)
			(S.L.lights_nebelschluss)
			(S.L.cp_light_pull)
		{endif}
		(L.L.light_mode) 1 =
		{if}
			(L.L.elec_busbar_main) sqr
			(S.L.lights_stand)
			(S.L.lights_rueck)
			(S.L.lights_rueck_2)
			1 (S.L.lights_terminus)
			0.25 (S.L.VDV_lightswitch_anim)

			0
			(S.L.lights_nebelschw)
			(S.L.lights_nebelschluss)
			(S.L.lights_abbl)
			(S.L.cp_light_pull)
		{endif}
		(L.L.light_mode) 2 =
		{if}
			(L.L.elec_busbar_main) sqr
			(S.L.lights_abbl)
			(S.L.lights_stand)
			(S.L.lights_rueck)
			(S.L.lights_rueck_2)
			1 (S.L.lights_terminus)
			0.5 (S.L.VDV_lightswitch_anim)

			0
			(S.L.lights_nebelschw)
			(S.L.lights_nebelschluss)
			(S.L.cp_light_pull)

			(L.L.engine_n) 100 <
			{if}
				0 (S.L.lights_abbl)
			{endif}
		{endif}
		(L.L.light_mode) 3 =
		{if}
			(L.L.elec_busbar_main) sqr
			(S.L.lights_abbl)
			(S.L.lights_nebelschw)
			(S.L.lights_stand)
			(S.L.lights_rueck)
			(S.L.lights_rueck_2)
			1 (S.L.lights_terminus)
			0.5 (S.L.cp_light_pull)

			(L.L.engine_n) 100 <
			{if}
				0 (S.L.lights_abbl) (S.L.lights_nebelschw)
			{endif}
		{endif}
		(L.L.light_mode) 4 =
		{if}
			(L.L.elec_busbar_main) sqr
			(S.L.lights_abbl)
			(S.L.lights_nebelschluss)
			(S.L.lights_nebelschw)
			(S.L.lights_stand)
			(S.L.lights_rueck)
