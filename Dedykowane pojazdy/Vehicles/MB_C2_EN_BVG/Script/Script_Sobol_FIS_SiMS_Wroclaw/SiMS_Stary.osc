	{if}
		"kwietnia" (S.$.XTL_MiesiacSformatowany)
	{endif}

	(L.L.XTL_Miesiac) 5 =
	{if}
		"maja" (S.$.XTL_MiesiacSformatowany)
	{endif}

	(L.L.XTL_Miesiac) 6 =
	{if}
		"czerwca" (S.$.XTL_MiesiacSformatowany)
	{endif}

	(L.L.XTL_Miesiac) 7 =
	{if}
		"lipca" (S.$.XTL_MiesiacSformatowany)
	{endif}

	(L.L.XTL_Miesiac) 8 =
	{if}
		"sierpnia" (S.$.XTL_MiesiacSformatowany)
	{endif}

	(L.L.XTL_Miesiac) 9 =
	{if}
		"września" (S.$.XTL_MiesiacSformatowany)
	{endif}

	(L.L.XTL_Miesiac) 10 =
	{if}
		"października" (S.$.XTL_MiesiacSformatowany)
	{endif}

	(L.L.XTL_Miesiac) 11 =
	{if}
		"listopada" (S.$.XTL_MiesiacSformatowany)
	{endif}

	(L.L.XTL_Miesiac) 12 =
	{if}
		"grudnia" (S.$.XTL_MiesiacSformatowany)
	{endif}

