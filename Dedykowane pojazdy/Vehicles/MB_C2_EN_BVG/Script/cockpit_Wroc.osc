' Modding_Modus 0 = weg 1 = Fahrplan 2 = Modding

{trigger:rozklad_wyjmij}
1 (S.L.rozklad)
{end}

{trigger:rozklad_schowaj}
0 (S.L.rozklad)
{end}

{trigger:Fahrplan_C2}
1 (S.L.Fahrplan_C2)
1 (S.L.Modding_Modus)
{end}

{trigger:Fahrplan_C2_zurueck}
0 (S.L.Fahrplan_C2)
0 (S.L.Modding_Modus)
{end}

{trigger:Fahrplan_C2_Modding}
1 (S.L.Fahrplan_C2)
2 (S.L.Modding_Modus)
{end}

{trigger:Modding_Fehler}
0 (S.L.Modding_Menue_Timer)
"Einstellung nicht verfuegbar" (S.$.Modding_Text)
{end}

{trigger:grosse_Klima}
0 (S.L.Klima_Variante)

(L.L.Klima_Variante) 0 =
{if}
	(L.L.neue_Decke) 0 =
	{if}
	1 (S.L.Klima_Gross)
	{else}
	2 (S.L.Klima_Gross)
	{endif}
0 (S.L.Klima_Klein)
"Klima Gross" (S.$.Modding_Text)
{else}
	(L.L.neue_Decke) 0 =
	{if}
	1 (S.L.Klima_Klein)
	{else}
	2 (S.L.Klima_Klein)
	{endif}
0 (S.L.Klima_Gross)
"Klima Klein" (S.$.Modding_Text)
{endif}
{end}

{trigger:kleine_Klima}
1 (S.L.Klima_Variante)

(L.L.Klima_Variante) 0 =
{if}
	(L.L.neue_Decke) 0 =
	{if}
	1 (S.L.Klima_Gross)
	{else}
	2 (S.L.Klima_Gross)
	{endif}
0 (S.L.Klima_Klein)
"Klima Gross" (S.$.Modding_Text)
{else}
	(L.L.neue_Decke) 0 =
	{if}
	1 (S.L.Klima_Klein)
	{else}
	2 (S.L.Klima_Klein)
	{endif}
0 (S.L.Klima_Gross)
"Klima Klein" (S.$.Modding_Text)
{endif}
{end}

{trigger:kein_Hybrid}
0 (S.L.Hybrid) (S.L.Hybridschriftzug_vorne)
{end}

{trigger:Hybrid}
1 (S.L.Hybrid)
{end}


{trigger:kein_Hybridschriftzug}
0 (S.L.Hybridschriftzug_vorne)
{end}

{trigger:Hybridschriftzug}
(L.L.Hybrid)
{if}
1 (S.L.Hybridschriftzug_vorne)
{endif}
{end}

{trigger:Hybridschriftzug_2}
1 (S.L.Hybridschriftzug_vorne)
{end}


{trigger:kein_Abbiegeassi}
0 (S.L.Abbiegeassistent)
{end}

{trigger:Abbiegeassi}
1 (S.L.Abbiegeassistent)
{end}

{trigger:kurzer_Spiegel}
1 (S.L.Aussenspiegel)
{end}

{trigger:langer_Spiegel}
0 (S.L.Aussenspiegel)
{end}

{trigger:lange_Hoerner}
1 (S.L.Hoerner)
{end}

{trigger:kurze_Hoerner}
0 (S.L.Hoerner)
{end}

{trigger:UEfront}
1 (S.L.Front_Stadt_UE)
{end}

{trigger:Stadtfront}
0 (S.L.Front_Stadt_UE)
{end}

{trigger:Matrix_Variante_1}
0 (S.L.Matrix_Variante)
{end}

{trigger:Matrix_Variante_2}
1 (S.L.Matrix_Variante)
{end}

{trigger:Matrix_Variante_3}
2 (S.L.Matrix_Variante)
{end}

{trigger:Matrix_Variante_3}
2 (S.L.Matrix_Variante)
{end}


{trigger:Wagennummer}
(L.L.Wagennummer_vis) ! (S.L.Wagennummer_vis) 
{end}



{trigger:Repaint_zurueck}
(L.L.Colorscheme) 1 - (S.L.Colorscheme)
{end}

{trigger:Repaint_vor}
(L.L.Colorscheme) 1 + (S.L.Colorscheme)
{end}



{trigger:alte_Decke}
0 (S.L.neue_Decke)
0 (S.L.Lawo_Innenanzeige_Uhrzeit_vis_alteDecke) (S.L.Lawo_Innenanzeige_Uhrzeit_vis_neueDecke)
(L.L.Klima_Variante) 0 =
{if}
	(L.L.neue_Decke) 0 =
	{if}
	1 (S.L.Klima_Gross)
	{else}
	2 (S.L.Klima_Gross)
	{endif}
0 (S.L.Klima_Klein)
{else}
	(L.L.neue_Decke) 0 =
	{if}
	1 (S.L.Klima_Klein)
	{else}
	2 (S.L.Klima_Klein)
	{endif}
0 (S.L.Klima_Gross)
{endif}
{end}

{trigger:neue_Decke}
1 (S.L.neue_Decke)
0 (S.L.Lawo_Innenanzeige_Uhrzeit_vis_alteDecke) (S.L.Lawo_Innenanzeige_Uhrzeit_vis_neueDecke)
(L.L.Klima_Variante) 0 =
{if}
	(L.L.neue_Decke) 0 =
	{if}
	1 (S.L.Klima_Gross)
	{else}
	2 (S.L.Klima_Gross)
	{endif}
0 (S.L.Klima_Klein)
{else}
	(L.L.neue_Decke) 0 =
	{if}
	1 (S.L.Klima_Klein)
	{else}
	2 (S.L.Klima_Klein)
	{endif}
0 (S.L.Klima_Gross)
{endif}
{end}

{trigger:neue_Decke_2}
2 (S.L.neue_Decke)
0 (S.L.Lawo_Innenanzeige_Uhrzeit_vis_alteDecke) (S.L.Lawo_Innenanzeige_Uhrzeit_vis_neueDecke)
(L.L.Klima_Variante) 0 =
{if}
	(L.L.neue_Decke) 0 =
	{if}
	1 (S.L.Klima_Gross)
	{else}
	2 (S.L.Klima_Gross)
	{endif}
0 (S.L.Klima_Klein)
{else}
	(L.L.neue_Decke) 0 =
	{if}
	1 (S.L.Klima_Klein)
	{else}
	2 (S.L.Klima_Klein)
	{endif}
0 (S.L.Klima_Gross)
{endif}
{end}



{trigger:blinker_warn_toggle}
	(L.L.lights_sw_warnblinker) ! (S.L.lights_sw_warnblinker) 
	{if}
		(M.L.lights_calc_geberfaktor)
		(M.L.lights_startblinkgeber)
	{endif}
		(T.L.ev_VDV_Warnblinker)
1 (S.L.warnblinker_taster)
{end}

{trigger:blinker_warn_toggle_off}
0 (S.L.warnblinker_taster)
{end}




{trigger:automatic_R}

0 (S.L.cockpit_gangN)
	(C.L.cockpit_gangwahltaster_alt)
	{if}
		(L.L.cockpit_gang2) (L.L.cockpit_gang3) ||
		{if}
			(L.L.antrieb_getr_gangvorwahl) 1 <= !
				{if}
					(L.S.getTime) (C.L.antrieb_gangwahlzeit) (C.L.antrieb_neutralwahlzeit) - - (S.L.antrieb_getr_gangwahlzeitpunkt)
				{endif}
			1 (S.L.antrieb_getr_gangvorwahl)
		{endif}
		(L.L.cockpit_gangR_toggle) ! (S.L.cockpit_gangR_toggle)
		(L.L.cockpit_gangR) !
		{if}
			1 (S.L.cockpit_gang_r-frei)
		{endif}
		(L.L.cockpit_gangR_toggle) (L.L.cockpit_gang2_toggle) ! (L.L.cockpit_gang3_toggle) ! && &&
		{if}
			(L.S.getTime) (S.L.antrieb_getr_gangwahlzeitpunkt)
			(L.L.brake) 0.1 >
			{if}
			0 (S.L.antrieb_getr_gangvorwahl)
			{endif}
		{endif}
		(L.L.cockpit_gangR) 1 = !
		{if}
			(L.L.cockpit_gangR_toggle)
			{if}
				(T.L.ev_gangwahltaster_old_on)
			{else}
				(T.L.ev_gangwahltaster_old_off)
			{endif}
		{endif}
		1 (S.L.cockpit_gangR)	
	{else}
		(L.L.antrieb_getr_gangvorwahl) 1 <= 
		(L.L.cockpit_gang3) 0 = &&
		{if}
			(L.L.antrieb_getr_gangvorwahl) 0 = !
			{if}
				(T.L.ev_gangwahltaster)
				(L.S.getTime) (S.L.antrieb_getr_gangwahlzeitpunkt)
			{endif}
			
			(L.L.brake) 0.1 >
			{if}
			0 (S.L.antrieb_getr_gangvorwahl)
			{endif}
				
			1 (S.L.cockpit_gangR)
		{endif}
	{endif}

{end}

{trigger:automatic_R_off}
	(C.L.cockpit_gangwahltaster_alt)
	{if}
		(L.L.cockpit_gangR_toggle) 
		{if}
			0.7 (S.L.cockpit_gangR)
			0 (S.L.cockpit_gang_r-frei)	
		{else}
			(L.L.cockpit_gang3_toggle) (L.L.cockpit_gang2_toggle) ! &&
			{if}
				(L.S.getTime) (S.L.antrieb_getr_gangwahlzeitpunkt)
				4 (S.L.antrieb_getr_gangvorwahl)
			{else}
				(L.L.cockpit_gang2_toggle) 
				{if}
					(L.S.getTime) (S.L.antrieb_getr_gangwahlzeitpunkt)
					3 (S.L.antrieb_getr_gangvorwahl)
				{else}

					(L.S.getTime) (C.L.antrieb_gangwahlzeit) (C.L.antrieb_neutralwahlzeit) - - (S.L.antrieb_getr_gangwahlzeitpunkt)
					1 (S.L.antrieb_getr_gangvorwahl)
				{endif}
				
			{endif}
			0 (S.L.cockpit_gangR) 0 (S.L.cockpit_gang_r-frei)	
		{endif}
	{else}
		(L.L.cockpit_gangR) 1 =
		{if}
			0.7 (S.L.cockpit_gangR)
		{endif}
	{endif}
{end}



{trigger:automatic_R_mouse}

0 (S.L.cockpit_gangN)
	(C.L.cockpit_gangwahltaster_alt)
	{if}
		(L.L.cockpit_gang2) (L.L.cockpit_gang3) ||
		{if}
			(L.L.antrieb_getr_gangvorwahl) 1 <= !
				{if}
					(L.S.getTime) (C.L.antrieb_gangwahlzeit) (C.L.antrieb_neutralwahlzeit) - - (S.L.antrieb_getr_gangwahlzeitpunkt)
				{endif}
			1 (S.L.antrieb_getr_gangvorwahl)
		{endif}
		(L.L.cockpit_gangR_toggle) ! (S.L.cockpit_gangR_toggle)
		(L.L.cockpit_gangR) 1 = !
		{if}
			(L.L.cockpit_gangR_toggle)
			{if}
				(T.L.ev_gangwahltaster_old_on)
			{else}
				(T.L.ev_gangwahltaster_old_off)
			{endif}
		{endif}
		1 (S.L.cockpit_gangR)	
	{else}
		(L.L.antrieb_getr_gangvorwahl) 1 <= 
		{if}
			(L.L.antrieb_getr_gangvorwahl) 0 = !
			{if}
				(T.L.ev_gangwahltaster)
				(L.S.getTime) (S.L.antrieb_getr_gangwahlzeitpunkt)
			{endif}
			(L.L.brake) 0.1 >
			{if}
			0 (S.L.antrieb_getr_gangvorwahl)
			{endif}
	
			1 (S.L.cockpit_gangR)
		{endif}
	{endif}
{end}

{trigger:automatic_R_mouse_off}
	(C.L.cockpit_gangwahltaster_alt)
	{if}
		(L.L.cockpit_gangR_toggle) 
		{if}
			0.7 (S.L.cockpit_gangR)
		{else}
			(L.L.cockpit_gang3_toggle) (L.L.cockpit_gang2_toggle) ! &&
			{if}
				(L.S.getTime) (S.L.antrieb_getr_gangwahlzeitpunkt)
				4 (S.L.antrieb_getr_gangvorwahl)
			{else}
				(L.L.cockpit_gang2_toggle) 
				{if}
					(L.S.getTime) (S.L.antrieb_getr_gangwahlzeitpunkt)
					3 (S.L.antrieb_getr_gangvorwahl)
				{else}

					(L.S.getTime) (C.L.antrieb_gangwahlzeit) (C.L.antrieb_neutralwahlzeit) - - (S.L.antrieb_getr_gangwahlzeitpunkt)
					1 (S.L.antrieb_getr_gangvorwahl)
				{endif}
				
			{endif}
			0 (S.L.cockpit_gangR)			
		{endif}
	{else}
		(L.L.cockpit_gangR) 1 =
		{if}
			0.7 (S.L.cockpit_gangR)
		{endif}
	{endif}
{end}


{trigger:automatic_N}

		(L.L.cockpit_gangR) 0.5 >
		(L.L.cockpit_gang3) 0.5 > ||
		{if}
			(T.L.ev_gangwahltaster_N)
		{endif}
		(L.L.antrieb_getr_gangvorwahl) 1 = !
			{if}
				(L.S.getTime) (C.L.antrieb_gangwahlzeit) (C.L.antrieb_neutralwahlzeit) -  - (S.L.antrieb_getr_gangwahlzeitpunkt)
			{endif}
		1 (S.L.antrieb_getr_gangvorwahl) (S.L.cockpit_gangN)
		0 (S.L.cockpit_gangR) (S.L.cockpit_gang1) (S.L.cockpit_gang2) (S.L.cockpit_gang3)
{end}


{trigger:automatic_N_off}
	(C.L.Voith_ZF)
	{if}
		1 (S.L.cockpit_gangN)
	{else}
		0 (S.L.cockpit_gangN)
	{endif}
{end}


