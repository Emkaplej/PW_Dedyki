'----------------------
'	Frame
'----------------------
{macro:cockpit_frame}

' Modding

(L.L.Modding_Modus) 2 =
{if}

(L.L.Modding_Menue_Timer) 5 >
{if}
"Modding Menue" (S.$.Modding_Text)
{endif}
(L.L.Modding_Menue_Timer) (L.S.Timegap) + 8 min (S.L.Modding_Menue_Timer)
{endif}


(L.L.Axle_Steering_0_L) 0.1 >
{if}
(L.L.Axle_Steering_0_L) (S.L.Lenkhilfe)
{else}
(L.L.Axle_Steering_0_L) -1 * (S.L.Lenkhilfe)
{endif}

' Dachluken Steuerung
(L.L.Dachluken_Modus) 0 =
{if}
0 (S.L.Dachluken_Vorne)
0 (S.L.Dachluken_Mitte)
0 (S.L.Dachluken_Hinten)
{endif}

(L.L.Dachluken_Modus) 1 =
{if}
0 (S.L.Dachluken_Vorne)
1 (S.L.Dachluken_Mitte)
1 (S.L.Dachluken_Hinten)
{endif}

(L.L.Dachluken_Modus) 2 =
{if}
0 (S.L.Dachluken_Vorne)
1 (S.L.Dachluken_Mitte)
0 (S.L.Dachluken_Hinten)
{endif}

(L.L.Dachluken_Modus) 3 =
{if}
1 (S.L.Dachluken_Vorne)
1 (S.L.Dachluken_Mitte)
0 (S.L.Dachluken_Hinten)
{endif}

' Lampe auf Schalter

(L.L.Dachluken_Modus) 1 =
(L.L.Dachluken_Modus) 2 = ||
{if}
1 (S.L.Dachluken_Lampe_unten)
{else}
0 (S.L.Dachluken_Lampe_unten)
{endif}

(L.L.Dachluken_Modus) 3 =
(L.L.Dachluken_Modus) 2 = ||
{if}
1 (S.L.Dachluken_Lampe_oben)
{else}
0 (S.L.Dachluken_Lampe_oben)
{endif}

(L.L.neue_Decke) 0 =
{if}
	(L.L.Tuer2_IST_SST) 0 =
	{if}
	0 (S.L.Tuer2Lampe)
	0 (S.L.Tuer2Nothahn)
	0 (S.L.Tuer2Seitenbalken)
	0 (S.L.Tuer2Decke)
	0 (S.L.Tuer2_Innen)
	{else}
	2 (S.L.Tuer2Lampe)
	1 (S.L.Tuer2Nothahn)
	1 (S.L.Tuer2Seitenbalken)
	3 (S.L.Tuer2Decke)
	2 (S.L.Tuer2_Innen)
	{endif}
	(L.L.Tuer3_IST_SST) 0 =
	{if}
	0 (S.L.Tuer3Lampe)
	0 (S.L.Tuer3Nothahn)
	0 (S.L.Tuer3Seitenbalken)
	0 (S.L.Tuer3Decke)
	0 (S.L.Tuer3_Innen)
	{else}
	2 (S.L.Tuer3Lampe)
	1 (S.L.Tuer3Nothahn)
	1 (S.L.Tuer3Seitenbalken)
	3 (S.L.Tuer3Decke)
	2 (S.L.Tuer3_Innen)
	{endif}
	(L.L.Tuer4_IST_SST) 0 =
	{if}
	0 (S.L.Tuer4Lampe)
	0 (S.L.Tuer4Nothahn)
	0 (S.L.Tuer4Seitenbalken)
	0 (S.L.Tuer4Decke)
	0 (S.L.Tuer4_Innen)
	{else}
	2 (S.L.Tuer4Lampe)
	1 (S.L.Tuer4Nothahn)
	1 (S.L.Tuer4Seitenbalken)
	3 (S.L.Tuer4Decke)
	2 (S.L.Tuer4_Innen)
	{endif}
{endif}
(L.L.neue_Decke) 1 =
{if}
	(L.L.Tuer2_IST_SST) 0 =
	{if}
	0 (S.L.Tuer2Lampe)
	0 (S.L.Tuer2Nothahn)
	2 (S.L.Tuer2Seitenbalken)
	1 (S.L.Tuer2Decke)
	0 (S.L.Tuer2_Innen)
	{else}
	3 (S.L.Tuer2Lampe)
	2 (S.L.Tuer2Nothahn)
	2 (S.L.Tuer2Seitenbalken)
	4 (S.L.Tuer2Decke)
	2 (S.L.Tuer2_Innen)
	{endif}
	(L.L.Tuer3_IST_SST) 0 =
	{if}
	0 (S.L.Tuer3Lampe)
	0 (S.L.Tuer3Nothahn)
	2 (S.L.Tuer3Seitenbalken)
	1 (S.L.Tuer3Decke)
	0 (S.L.Tuer3_Innen)
	{else}
	3 (S.L.Tuer3Lampe)
	2 (S.L.Tuer3Nothahn)
	2 (S.L.Tuer3Seitenbalken)
	4 (S.L.Tuer3Decke)
	2 (S.L.Tuer3_Innen)
	{endif}
	(L.L.Tuer4_IST_SST) 0 =
	{if}
	0 (S.L.Tuer4Lampe)
	0 (S.L.Tuer4Nothahn)
	2 (S.L.Tuer4Seitenbalken)
	1 (S.L.Tuer4Decke)
	0 (S.L.Tuer4_Innen)
	{else}
	3 (S.L.Tuer4Lampe)
	2 (S.L.Tuer4Nothahn)
	2 (S.L.Tuer4Seitenbalken)
	4 (S.L.Tuer4Decke)
	2 (S.L.Tuer4_Innen)
	{endif}
{endif}
(L.L.neue_Decke) 2 =
{if}
	(L.L.Tuer2_IST_SST) 0 =
	{if}
	1 (S.L.Tuer2Lampe)
	0 (S.L.Tuer2Nothahn)
	3 (S.L.Tuer2Seitenbalken)
	2 (S.L.Tuer2Decke)
	1 (S.L.Tuer2_Innen)
	{else}
	4 (S.L.Tuer2Lampe)
	2 (S.L.Tuer2Nothahn)
	3 (S.L.Tuer2Seitenbalken)
	5 (S.L.Tuer2Decke)
	3 (S.L.Tuer2_Innen)
	{endif}
	(L.L.Tuer3_IST_SST) 0 =
	{if}
	1 (S.L.Tuer3Lampe)
	0 (S.L.Tuer3Nothahn)
	3 (S.L.Tuer3Seitenbalken)
	2 (S.L.Tuer3Decke)
	1 (S.L.Tuer3_Innen)
	{else}
	4 (S.L.Tuer3Lampe)
	2 (S.L.Tuer3Nothahn)
	3 (S.L.Tuer3Seitenbalken)
	5 (S.L.Tuer3Decke)
	3 (S.L.Tuer3_Innen)
	{endif}
	(L.L.Tuer4_IST_SST) 0 =
	{if}
	1 (S.L.Tuer4Lampe)
	0 (S.L.Tuer4Nothahn)
	3 (S.L.Tuer4Seitenbalken)
	2 (S.L.Tuer4Decke)
	1 (S.L.Tuer4_Innen)
	{else}
	4 (S.L.Tuer4Lampe)
	2 (S.L.Tuer4Nothahn)
	3 (S.L.Tuer4Seitenbalken)
	5 (S.L.Tuer4Decke)
	3 (S.L.Tuer4_Innen)
	{endif}
{endif}

' Dashboard Uhrzeit
(L.S.Time) 3600 / s0 trunc s1 "02" $IntToStrEnh ":" $+ l0 l1 - 60 * trunc "02" $IntToStrEnh $+
(S.$.Dashboard_Uhrzeit)

' Dashboard Aussentemperatur
(L.S.Weather_Temperature) $IntToStr (S.$.Dashboard_Temperatur)

' Dashboard Kilometerstand
(L.L.km_counter_km) trunc " 6" $IntToStrEnh "." $+ (L.L.km_counter_m) trunc $IntToStr $+ (S.$.Dashboard_Kilometer_Step2)

' Dashboard Tageskilometerstand
(L.L.km_counter_km_day) trunc " 3" $IntToStrEnh "." $+ (L.L.km_counter_m_day) trunc $IntToStr $+ (S.$.Dashboard_Tageskilometer_Step2)


' Dashboard Kilometerstand
(L.L.km_counter_km) trunc " 6" $IntToStrEnh (S.$.Dashboard_Kilometer)

' Dashboard Tageskilometerstand
(L.L.km_counter_km_day) trunc " 3" $IntToStrEnh (S.$.Dashboard_Tageskilometer)

		(L.L.km_counter_m_day) trunc $IntToStr
		(S.$.Dashboard_Tageskilometer_Meter)


' Dashboard Text
(L.$.Dashboard_Uhrzeit) "  " $+ (L.$.Dashboard_Temperatur) $+ " " $+ (L.$.Dashboard_Kilometer) $+ " " $+ (L.$.Dashboard_Tageskilometer) $+ "  " $+ (L.$.Dashboard_Tageskilometer_Meter) $+
(S.$.Dashboard_Text)

' Dashboard Text Step 2
(L.$.Dashboard_Uhrzeit) "  " $+ (L.$.Dashboard_Temperatur) $+ " " $+ (L.$.Dashboard_Kilometer_Step2) $+ " " $+ (L.$.Dashboard_Tageskilometer_Step2) $+
(S.$.Dashboard_Text_Step2)


(L.L.elec_busbar_main)
{if}

	(L.L.neue_Decke)
	{if}
	0 (S.L.alte_Decke_Haltewunsch)
	0 (S.L.alte_Decke_Monitor)

		(L.L.haltewunschlampe)
		{if}
		1 (S.L.neue_Decke_Haltewunsch)
		{else}
		0 (S.L.neue_Decke_Haltewunsch)
		{endif}

		(L.L.elec_busbar_main)
		{if}
		1 (S.L.neue_Decke_Monitor)
		{else}
		0 (S.L.neue_Decke_Monitor)
		{endif}

	{else}
	0 (S.L.neue_Decke_Haltewunsch)
	0 (S.L.neue_Decke_Monitor)

		(L.L.haltewunschlampe)
		{if}
		1 (S.L.alte_Decke_Haltewunsch)
		{else}
		0 (S.L.alte_Decke_Haltewunsch)
		{endif}

		(L.L.elec_busbar_main)
		{if}
		1 (S.L.alte_Decke_Monitor)
		{else}
		0 (S.L.alte_Decke_Monitor)
		{endif}

	{endif}

{else}
0 (S.L.neue_Decke_Haltewunsch)
0 (S.L.alte_Decke_Haltewunsch)
0 (S.L.neue_Decke_Monitor)
0 (S.L.alte_Decke_Monitor)
{endif}


(L.L.elec_busbar_main)
{if}

    (L.L.VDL_DUMMY_16) 1 =
    {if}
        0 (S.L.taster_rot_fahrertuer)
    {else}
        1 (S.L.taster_rot_fahrertuer)
    {endif}

    (C.L.cockpit_has_retarderswitch)
    {if}
        (L.L.cp_retarder_sw) (S.L.retarder_off_light)
    {else}
        (L.L.cp_retarder_sw_direkt) ! (S.L.retarder_off_light)
    {endif}

{else}
    0 (S.L.taster_rot_fahrertuer)
    0 (S.L.retarder_off_light)
{endif}

(L.L.ecas_kneel) 0 =
{if}
0 (S.L.taster_rot_kneeling)
{else}
1 (S.L.taster_rot_kneeling)
{endif}
{endif}


(L.L.Seiten_unten_DUMMY_2) 0 =
(L.L.elec_busbar_main) &&
{if}
1 (S.L.BVG_USB_an)
{else}
0 (S.L.BVG_USB_an)
{endif}


(L.L.elec_busbar_main)
{if}


	(L.L.lights_sw_blinker) 2 =
	{if}
	1 (S.L.Rosho_Cam_an)
	0 (S.L.cam_timer)
	{else}
	(L.L.cam_timer) (L.S.Timegap) + 5 min (S.L.cam_timer)

		(L.L.cam_timer) 3 >
		{if}
		0 (S.L.Rosho_Cam_an)
		{endif}
	{endif}
{else}
0 (S.L.Rosho_Cam_an)
{endif}


(L.L.neue_Decke) 2 =
{if}
2 (S.L.Rosho_Cam_an_alt)
	(L.L.Rosho_Cam_an) 0 =
	{if}
	0 (S.L.Rosho_Cam_an_neu)
	{else}
	1 (S.L.Rosho_Cam_an_neu)
	{endif}
{else}
2 (S.L.Rosho_Cam_an_neu)
	(L.L.Rosho_Cam_an) 0 =
	{if}
	0 (S.L.Rosho_Cam_an_alt)
	{else}
	1 (S.L.Rosho_Cam_an_alt)
	{endif}

{endif}

(L.L.elec_busbar_main)
{if}
	(L.L.door_2) 0.1 >
	{if}
	1 (S.L.2_Tuer_Cam_an)
	{else}
	0 (S.L.2_Tuer_Cam_an)
	{endif}
{else}
0 (S.L.2_Tuer_Cam_an)
{endif}



1 (S.L.Daueranimation)

'�bertragen der Schalterstellungen:
	(L.L.cp_retarder_sw) (S.L.antrieb_retarder_sw)
	(L.L.cp_retarder_sw_direkt) (S.L.antrieb_retarder_sw_direkt)
	(L.L.cp_wischer_schnell_sw) (S.L.wiper_schnell_sw)
	(L.L.cp_wischer_einaus_sw) (S.L.wiper_einaus_sw)
	(L.L.cp_wischer_intervall_sw) (S.L.wiper_intervall_sw)
	(L.L.cp_wischer_wascher_sw) (S.L.wiper_wascher_sw)

	1 (S.L.almex_static_anim)

	(C.L.vdv_blinker_tone_volume) 0 max 1 min (S.L.vdv_blinker_tone_volume)

	(M.L.tacho_frame)
	(M.L.uhr_frame)
	(M.L.drehzahlmesser_frame)
	(M.L.hupe_frame)
	(M.L.blinkerhebel_frame)
	(M.L.wischerhebel_frame)
	(M.L.wischer_drehschalter_frame)
	(M.L.oeldruck_frame)
	(M.L.tankuhr_frame)
	(M.L.cockpitlights_frame)
	(M.L.klimator_frame)
	(M.L.schluessel_frame)
	(M.L.odometer_frame)
