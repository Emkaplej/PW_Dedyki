		l0 0.17 <
		{if}
				0 (S.L.cp_wischer_intervall_sw) (S.L.cp_wischer_einaus_sw) (S.L.cp_wischer_schnell_sw)
				0 (S.L.cockpit_wischer_drehschalter_mode)	
		{else} 
			l0 0.5 <
