{trigger:retarder_off}

    (C.L.cockpit_has_retarderswitch)
    {if}
        (L.L.cp_retarder_sw) ! (S.L.cp_retarder_sw)

        (L.L.cp_retarder_sw) (S.L.retarder_off_anim)
        (L.L.cp_retarder_sw) (S.L.retarder_off_light)

        (L.L.cp_retarder_sw) 1 =
        {if}
            (T.L.ev_VDV_on)
        {else}
            (T.L.ev_VDV_off)
        {endif}

    {else}
        (L.L.cp_retarder_sw_direkt) ! (S.L.cp_retarder_sw_direkt)

        (L.L.cp_retarder_sw_direkt) (S.L.retarder_off_anim)
        (L.L.cp_retarder_sw_direkt) (S.L.retarder_off_light)

        (L.L.cp_retarder_sw_direkt) 1 =
        {if}
            (T.L.ev_VDV_on)
        {else}
            (T.L.ev_VDV_off)
        {endif}
    {endif}

{end}

{trigger:retarder_off_off}
{end}
