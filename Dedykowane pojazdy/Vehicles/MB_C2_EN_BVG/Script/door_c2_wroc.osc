{trigger:bus_doorfront0}
	(L.L.Door_Error_Count) 1 + (S.L.Door_Error_Count)
	1 (S.L.cockpit_tuertaster1)
	(T.L.ev_tuertaster_ein)
{end}

{trigger:bus_doorfront0_off}
	0 (S.L.cockpit_tuertaster1)
	(T.L.ev_tuertaster_aus)
{end}

{trigger:bus_doorfront1}

    (L.L.pandus_opn) 0 =
    {if}
        (L.L.elec_busbar_main)
        {if}
            (L.L.Door2_Error_Count) 1 + (S.L.Door2_Error_Count)
            (L.L.cockpit_tuertaster2) ! (S.L.cockpit_tuertaster2)
            0 (S.L.door_handsteuerung)
            1 (S.L.manuellesTueroeffnen)
        {endif}
    {endif}

    1 (S.L.cockpit_tuertaster2_2)
    (T.L.ev_tuertaster_ein)

{end}

{trigger:bus_doorfront1_off}
	0 (S.L.cockpit_tuertaster2_2)
	(T.L.ev_tuertaster_aus)
{end}


{trigger:bus_doorfront2}
	(L.L.Door3_Error_Count) 1 + (S.L.Door3_Error_Count)
	(L.L.cockpit_tuertaster2_Tuer3) ! (S.L.cockpit_tuertaster2_Tuer3)
	1 (S.L.cockpit_tuertaster2_2_Tuer3)
	(T.L.ev_tuertaster_ein)


	1 (S.L.manuellesTueroeffnen_Tuer3)
{end}

{trigger:bus_doorfront2_off}
	0 (S.L.cockpit_tuertaster2_2_Tuer3)
	(T.L.ev_tuertaster_aus)
{end}

{trigger:bus_dooraft_down}
    1 (S.L.dooraft_pressed)

    (L.L.bus_dooraft_sw) -0.5 <
    {if}
        0 (S.L.bus_dooraft_sw)

        0 (S.L.bremse_halte_sw)
        0 (S.L.Autoschalter_Tuer1) (S.L.Autoschalter_Tuer2)
        0 (S.L.Tuerfreigabe_Tueroefner)
        (T.L.Tuerfreigabe_off)
        (T.L.ev_VDV_off)

		1 (S.L.force_close_all)

		0 (S.L.doorTarget_01_delayed)
		0 (S.L.doorTarget_23_delayed)

		10 (S.L.doorAftLastOpen) (S.L.doorAftLastOpen1)

		0 (S.L.Haltewunsch_mit_Tuer_0) (S.L.Haltewunsch_mit_Tuer) (S.L.Haltewunsch_mit_Tuer_2)
		0 (S.L.door_haltewunsch_knopfdruck) (S.L.door_haltewunsch_knopfdruck_2)

        (L.L.door_handsteuerung)
        (L.L.bus_dooraft_sw) ! &&
        (L.L.bus_doorall_sw) ! &&
        {if}
            0 (S.L.door_handsteuerung)
            10 (S.L.doorAftLastOpen) (S.L.doorAftLastOpen1)
        {endif}

        (L.L.Door3_Error_Count) 1 + (S.L.Door3_Error_Count)

    {else}
        (L.L.bus_dooraft_sw) 0.5 >
        {if}
        {else}
            1 (S.L.bus_dooraft_sw)

            1 (S.L.bremse_halte_sw)
            1 (S.L.Autoschalter_Tuer1) (S.L.Autoschalter_Tuer2)
            1 (S.L.Tuerfreigabe_Tueroefner)
            (T.L.Tuerfreigabe)
            (T.L.ev_VDV_on)

            0 (S.L.force_close_all)

            (L.L.door_handsteuerung)
            (L.L.bus_dooraft_sw) ! &&
            (L.L.bus_doorall_sw) ! &&
            {if}
                0 (S.L.door_handsteuerung)
                10 (S.L.doorAftLastOpen) (S.L.doorAftLastOpen1)
            {endif}

            (L.L.Door3_Error_Count) 1 + (S.L.Door3_Error_Count)
        {endif}
    {endif}
{end}

{trigger:bus_dooraft_down_off}
    0 (S.L.dooraft_pressed)
{end}

{trigger:bus_dooraft_up}
    -1 (S.L.dooraft_pressed)

    (L.L.bus_dooraft_sw) 0.5 >
    {if}
        0 (S.L.bus_dooraft_sw)

        0 (S.L.bremse_halte_sw)
        0 (S.L.Autoschalter_Tuer1) (S.L.Autoschalter_Tuer2)
        0 (S.L.Tuerfreigabe_Tueroefner)
        (T.L.Tuerfreigabe_off)
        (T.L.ev_VDV_off)

		1 (S.L.force_close_all)

		0 (S.L.doorTarget_01_delayed)
		0 (S.L.doorTarget_23_delayed)

		10 (S.L.doorAftLastOpen) (S.L.doorAftLastOpen1)

		0 (S.L.Haltewunsch_mit_Tuer_0) (S.L.Haltewunsch_mit_Tuer) (S.L.Haltewunsch_mit_Tuer_2)
		0 (S.L.door_haltewunsch_knopfdruck) (S.L.door_haltewunsch_knopfdruck_2)


        (L.L.door_handsteuerung)
        (L.L.bus_dooraft_sw) ! &&
        (L.L.bus_doorall_sw) ! &&
        {if}
            0 (S.L.door_handsteuerung)
            10 (S.L.doorAftLastOpen) (S.L.doorAftLastOpen1)
        {endif}

        (L.L.Door3_Error_Count) 1 + (S.L.Door3_Error_Count)

    {else}
        (L.L.bus_dooraft_sw) -0.5 <
        {if}

        {else}
            -1 (S.L.bus_dooraft_sw)

            1 (S.L.bremse_halte_sw)
            1 (S.L.Autoschalter_Tuer1) (S.L.Autoschalter_Tuer2)
            1 (S.L.Tuerfreigabe_Tueroefner)
            (T.L.Tuerfreigabe)
            (T.L.ev_VDV_on)

            0 (S.L.force_close_all)

            (L.L.door_handsteuerung)
            (L.L.bus_dooraft_sw) ! &&
            (L.L.bus_doorall_sw) ! &&
            {if}
                0 (S.L.door_handsteuerung)
                10 (S.L.doorAftLastOpen) (S.L.doorAftLastOpen1)
            {endif}

            (L.L.Door3_Error_Count) 1 + (S.L.Door3_Error_Count)
        {endif}
    {endif}
{end}

{trigger:bus_dooraft_up_off}
    0 (S.L.dooraft_pressed)
{end}

{trigger:Tuerfreigabe}
    (L.L.bus_dooraft_sw) ! (S.L.bus_dooraft_sw)
    (L.L.bus_dooraft_sw) (S.L.bremse_halte_sw)

    (L.L.bus_dooraft_sw) abs 0.5 >
    {if}
        (T.L.ev_VDV_on)
    {else}
        1 (S.L.force_close_all)
        (T.L.ev_VDV_off)
    {endif}
{end}

{trigger:Tuerfreigabe_off}
    
{end}


' Haltestellenbremse
{trigger:bus_20h-switch}

(L.L.door_20h_sw) ! (S.L.door_20h_sw)
(L.L.hst_bremse_sw) ! (S.L.hst_bremse_sw)

	(L.L.hst_bremse_sw)
	{if}
		(T.L.ev_VDV_on)
	{else}
		(T.L.ev_VDV_off)
	{endif}
{end}

{trigger:bus_doorall_down}
    1 (S.L.bus_doorall)
    1 (S.L.doorall_pressed)
	
	1 (S.L.bus_doorall_sw)
    (T.L.ev_VDV_toggle_on)
	
	0 (S.L.force_close_all)
	0 (S.L.doorAftLastOpen) (S.L.doorAftLastOpen1)

	0 (S.L.doortimer23) (S.L.trigger_antirepeat23) (S.L.doorwarn_sent23)
	0 (S.L.doortimer45) (S.L.trigger_antirepeat45) (S.L.doorwarn_sent45)
	0 (S.L.doorTarget_23_delayed)

    (L.L.velocity) 0.1 <
    (L.L.velocity) -0.1 > &&
    {if}

        (L.L.tuersperre) 0 =
        {if}
            (L.L.doorTarget_0) 0 =
            {if}
                1 (S.L.doorTarget_0)
                (T.L.ev_doortriggeropen_0)
            {endif}

            (L.L.doorTarget_1) 0 =
            {if}
                1 (S.L.doorTarget_1)
                (T.L.ev_doortriggeropen_1)
            {endif}
        {endif}

        (L.L.tuersperre) 0 <
        {if}
            (L.L.doorTarget_1) 0 =
            {if}
                1 (S.L.doorTarget_1)
                (T.L.ev_doortriggeropen_1)
            {endif}
        {endif}

        (L.L.tuersperre) 0 >
        {if}
            (L.L.doorTarget_0) 0 =
            {if}
                1 (S.L.doorTarget_0)
                (T.L.ev_doortriggeropen_0)
            {endif}
        {endif}

        (L.L.doorTarget_23_delayed) 0 =
        (L.L.doorTarget_23) 0 = &&
        {if}
            1 (S.L.doorTarget_23) (S.L.doorTarget_23_delayed)

            (L.L.Tuer2_IST_SST) 0 =
            {if}  (T.L.ev_doortriggeropen_2)
            {else} (T.L.ev_doortriggeropen_2_SST)
            {endif}
        {endif}

        (L.L.doorTarget_45) 0 =
        {if}
            1 (S.L.doorTarget_45)

            (L.L.Tuer3_IST_SST) 0 =
            {if}  (T.L.ev_doortriggeropen_5)
            {else} (T.L.ev_doortriggeropen_5_SST)
            {endif}

            0 (S.L.doortimer45)
        {endif}

        0 (S.L.doorAftLastOpen1)
    {endif}
{end}

{trigger:bus_doorall_down_off}
    0 (S.L.bus_doorall)
    0 (S.L.doorall_pressed)
    (T.L.ev_VDV_toggle_off)
{end}

{trigger:bus_doorall_up}
    1 (S.L.bus_doorall)
    -1 (S.L.doorall_pressed)
    0 (S.L.bus_doorall_sw)
    (T.L.ev_VDV_toggle_on)

    (M.L.CloseGuard_01) !
    {if}
        (L.L.door_0) 0.05 >
        (L.L.door_1) 0.05 > ||
        {if}
            1 (S.L.close_lock01)

            (C.L.tuerverzoegerung) 0 >
            {if}
                1 (S.L.trigger_antirepeat01)
                0 (S.L.doortimer01)
            {else}
                (M.L.doorwarn_01)
                0 (S.L.doorTarget_0) (S.L.doorTarget_1)
                (T.L.ev_doortriggerclose_0)
                (T.L.ev_doortriggerclose_1)
            {endif}
        {endif}
    {endif}

    (M.L.CloseGuard_23) !
    {if}
        (M.L.RequestClose_23)
    {endif}

    (M.L.CloseGuard_45) !
    {if}
        (L.L.door_4) 0.05 >
        (L.L.door_5) 0.05 > || 
        {if}
            1 (S.L.close_lock45)

            (C.L.tuerverzoegerung) 0 =
            {if}
                0 (S.L.doorTarget_45)
                0 (S.L.doortimer45) (S.L.trigger_antirepeat45)

                (L.L.Tuer3_IST_SST) 0 =
                {if}
                    (T.L.ev_doortriggerclose_5)
                {else}
                    (T.L.ev_doortriggerclose_5_SST)
                {endif}
            {else}
                (L.L.doorwarn_sent45) 0 =
                {if}
                    (M.L.doorwarn_45)
                {endif}

                1 (S.L.trigger_antirepeat45)
                0 (S.L.doortimer45)
            {endif}
        {endif}
    {endif}

    0 (S.L.doorTarget_01_delayed)
    0 (S.L.doorTarget_23_delayed)

    10 (S.L.doorAftLastOpen) (S.L.doorAftLastOpen1)

    0 (S.L.Haltewunsch_mit_Tuer_0) (S.L.Haltewunsch_mit_Tuer) (S.L.Haltewunsch_mit_Tuer_2)
    0 (S.L.door_haltewunsch_knopfdruck) (S.L.door_haltewunsch_knopfdruck_2)

{end}

{trigger:bus_doorall_up_off}
    0 (S.L.bus_doorall)
    0 (S.L.doorall_pressed)
    (T.L.ev_VDV_toggle_off)
{end}

{trigger:int_haltewunsch}
	1 (S.L.haltewunsch)
{end}

{trigger:taster_haltewunsch}
	(L.L.bremse_halte_sw) 0 =
	{if}
	1 (S.L.Haltewunsch_mit_Tuer) (S.L.haltewunsch)
	{else}
	1 (S.L.haltewunsch)
	{endif}
{end}

{trigger:door_haltewunsch}
	1 (S.L.haltewunsch) (S.L.door_haltewunsch_knopfdruck)
{end}

{trigger:door_haltewunsch_off}
	0 (S.L.door_haltewunsch_knopfdruck)
{end}


{trigger:taster_haltewunsch_2}
	(L.L.bremse_halte_sw) 0 =
	{if}
	1 (S.L.Haltewunsch_mit_Tuer_2) (S.L.haltewunsch)
	{else}
	1 (S.L.haltewunsch)
	{endif}
{end}

{trigger:door_haltewunsch_2}
	1 (S.L.haltewunsch) (S.L.door_haltewunsch_knopfdruck_2)
{end}

{trigger:door_haltewunsch_2_off}
	0 (S.L.door_haltewunsch_knopfdruck_2)
{end}

{trigger:door_haltewunsch_Rolli}
	1 (S.L.haltewunsch) (S.L.door_haltewunsch_knopfdruck)
	1 (S.L.Haltewunsch_Rollstuhl) (S.L.Kinderwagen_Display)
	1 (S.L.Haltewunsch_mit_Tuer)
{end}

{trigger:door_haltewunsch_Rolli_off}
	0 (S.L.door_haltewunsch_knopfdruck)
{end}

{trigger:CG_1}
    (L.L.bus_dooraft_sw) abs 0.5 >
    {if}
        1 (S.L.Haltewunsch_mit_Tuer_0)
    {else}
        1 (S.L.haltewunsch)
        1 (S.L.Haltewunsch_mit_Tuer_0)
    {endif}
{end}

{trigger:CG_1_off}
{end}


{trigger:CG_2}
    (L.L.bus_dooraft_sw) abs 0.5 >
    {if}
        1 (S.L.Haltewunsch_mit_Tuer)
    {else}
        1 (S.L.haltewunsch)
        1 (S.L.Haltewunsch_mit_Tuer)
    {endif}
{end}

{trigger:CG_2_off}
{end}


{trigger:CG_3}
    (L.L.bus_dooraft_sw) abs 0.5 >
    {if}
        1 (S.L.Haltewunsch_mit_Tuer_2)
