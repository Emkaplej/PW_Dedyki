            {if}
				1 (S.L.close_lock01)
                1 (S.L.trigger_antirepeat01)
                0 (S.L.doortimer01)
                0 (S.L.autodoor_idle01)
            {endif}
        {else}
            0 (S.L.autodoor_idle01)
        {endif}


        (L.L.PAX_Exit2_Req)
        (L.L.PAX_Exit3_Req) ||
        (L.L.PAX_Entry2_Req) ||
        (L.L.PAX_Entry3_Req) ||
        (L.L.door_haltewunsch_knopfdruck) ||
        (L.L.Haltewunsch_mit_Tuer) ||
        (L.L.pandus_opn) ||
        (L.L.cockpit_tuertaster2_2) ||
        {if}
            0 (S.L.autodoor_idle23)
        {endif}

        (L.L.doorTarget_23) 1 =
        (L.L.door_2) 0.95 > &&
        (L.L.door_3) 0.95 > &&
        (L.L.PAX_Exit2_Req) ! &&
        (L.L.PAX_Exit3_Req) ! &&
        (L.L.PAX_Entry2_Req) ! &&
        (L.L.PAX_Entry3_Req) ! &&
        (L.L.door_haltewunsch_knopfdruck) ! &&
        (L.L.Haltewunsch_mit_Tuer) ! &&
        (L.L.cockpit_tuertaster2_2) ! &&
