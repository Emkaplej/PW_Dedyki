                    1 (S.L.close_lock23)
                    0 (S.L.doorTarget_23)
                    0 (S.L.doorTarget_23_delayed)
                    0 (S.L.doortimer23)
                    0 (S.L.trigger_antirepeat23)
                    0 (S.L.autodoor_idle23)
                {else}
                    1 (S.L.close_lock23)
                    0 (S.L.doorTarget_23)
                    0 (S.L.doorTarget_23_delayed)
                    0 (S.L.doortimer23)
                    0 (S.L.trigger_antirepeat23)
                    0 (S.L.autodoor_idle23)

                    (L.L.Tuer2_IST_SST) 0 =
