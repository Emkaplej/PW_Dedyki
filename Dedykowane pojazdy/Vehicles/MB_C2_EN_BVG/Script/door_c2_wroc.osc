                        (T.L.ev_doortriggerclose_2)
                    {else}
                        (T.L.ev_doortriggerclose_2_SST)
                    {endif}
                {endif}
            {endif}
        {else}
            0 (S.L.autodoor_idle23)
        {endif}


        (L.L.doorTarget_45) 1 =
        (L.L.trigger_antirepeat45) 1 = &&
