    (L.L.trigger_antirepeat45) 0.5 > ||
    (L.L.doortimer45) 0.001 > ||
    (L.L.doorTarget_45) 0 = (L.L.door_4) 0.02 > && ||
    (L.L.doorTarget_45) 0 = (L.L.door_5) 0.02 > && ||
{end}

{macro:door_traegheit}

'Simuliert tr�ges Verhalten (exponentiell)

'Ladekonventionen:
'	Sollwert		l0
'	Istwert			l1
'	Konstante Anlauf	l2 (Einheiten/s)
'	Konstante Ablauf	l3 (Einheiten/s)

'Anlauf oder Auslauf?
	l0 l1 > 
	{if}
		l2 (L.S.Timegap) * 1 min -1 max s4
	{else}
		l3 (L.S.Timegap) * 1 min -1 max s4
	{endif}


'Sollwert:
	l0
'Istwert:
	l1
'Beschleunigung:
	- l4 *
'Addition zum Istwert:
	l1 + s1
{end}