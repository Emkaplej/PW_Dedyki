    (M.L.CloseGuard_23) ||
    (M.L.CloseGuard_45) ||
{end}

{macro:CloseGuard_01}
    (L.L.close_lock01) 0.5 >
    (L.L.trigger_antirepeat01) 0.5 > ||
    (L.L.doortimer01) 0.001 > ||
    (L.L.doorTarget_0) 0 = (L.L.door_0) 0.02 > && ||
    (L.L.doorTarget_1) 0 = (L.L.door_1) 0.02 > && ||
{end}

{macro:CloseGuard_23}
