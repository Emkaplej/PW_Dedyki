{trigger:cp_autoschalter}
	(L.L.autoschalter) ! (S.L.autoschalter)	

	(L.L.autoschalter)
	{if}
		(T.L.ev_VDV_on)
	{else}
		(C.L.tuerverzoegerung) 0 >
		(L.L.door_2) 0.05 > (L.L.door_3) 0.05 > || &&
		{if}
			(M.L.doorwarn_23)
		{endif}

		0 (S.L.doorTarget_0) (S.L.doorTarget_1) (S.L.doorTarget_23)

		(L.L.door_0) 0.05 >
		(L.L.door_1) 0.05 > ||
		{if}
			(M.L.doorwarn_01)
			(T.L.ev_doortriggerclose_0)
		{endif}

		(L.L.door_2) 0.05 >
		(L.L.door_3) 0.05 > ||
		{if}
			(C.L.tuerverzoegerung) 0 >
			(L.L.doorwarn_sent23) 0 = &&
			{if}
				(M.L.doorwarn_23)
			{endif}

			0 (S.L.doorTarget_23)
			0 (S.L.doortimer23)
			0 (S.L.trigger_antirepeat23)
		{endif}

		(L.L.door_4) 0.05 >
		(L.L.door_5) 0.05 > ||
		{if}
			1 (S.L.trigger_antirepeat45)
			0 (S.L.doortimer45)
			(M.L.doorwarn_45)
		{endif}

		(T.L.ev_VDV_off)
	{endif}
{end}

{trigger:cp_schulfahrschalter}
	1 (S.L.schulfahrschaltung)	
	(T.L.ev_VDV_toggle_on)
	1 (S.L.schulfahrschalter_sw)
{end}

{trigger:cp_schulfahrschalter_off}	
