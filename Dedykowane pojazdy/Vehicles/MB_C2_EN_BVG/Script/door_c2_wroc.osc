        {if}
            (L.L.autodoor_idle23) (L.S.Timegap) + 3.5 min (S.L.autodoor_idle23)
            (L.L.autodoor_idle23) 3.5 >=
            {if}
            1 (S.L.close_lock23)

                (C.L.tuerverzoegerung) 0 >
                {if}
