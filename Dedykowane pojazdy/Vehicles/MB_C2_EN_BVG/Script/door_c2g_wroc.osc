{end}

{trigger:door0_drag}
	(L.S.mouse_x) -400 / (L.L.door_0_soll) + 1 min 0 max (S.L.door_0_soll)
{end}

{trigger:door1_drag}
	(L.S.mouse_x) -400 / (L.L.door_1_soll) + 1 min 0 max (S.L.door_1_soll)
{end}

{trigger:door2_drag}
	(L.S.mouse_x) -400 / (L.L.door_2_soll) + 1 min 0 max (S.L.door_2_soll)
{end}

{trigger:door3_drag}
	(L.S.mouse_x) -400 / (L.L.door_3_soll) + 1 min 0 max (S.L.door_3_soll)
{end}

{trigger:door4_drag}
	(L.S.mouse_x) -400 / (L.L.door_4_soll) + 1 min 0 max (S.L.door_4_soll)
{end}

{trigger:door5_drag}
	(L.S.mouse_x) -400 / (L.L.door_5_soll) + 1 min 0 max (S.L.door_5_soll)
{end}

{trigger:door6_drag}
	(L.S.mouse_x) -400 / (L.L.door_6_soll) + 1 min 0 max (S.L.door_6_soll)
{end}

{trigger:door7_drag}
	(L.S.mouse_x) -400 / (L.L.door_7_soll) + 1 min 0 max (S.L.door_7_soll)
{end}

{trigger:bus_doorfront0}
	(L.L.Door_Error_Count) 1 + (S.L.Door_Error_Count)
	1 (S.L.cockpit_tuertaster1)
{end}

{trigger:bus_doorfront0_off}
	0 (S.L.cockpit_tuertaster1)
{end}

{trigger:bus_doorfront1}
	(L.L.Door2_Error_Count) 1 + (S.L.Door2_Error_Count)
	1 (S.L.cockpit_tuertaster2)
{end}

{trigger:bus_doorfront1_off}
	0 (S.L.cockpit_tuertaster2)
{end}




' Autoschalter leasing (otwiera wszystkie drzwi)
{trigger:Tuerfreigabe}
1 (S.L.Autoschalter_Tuer1) (S.L.Autoschalter_Tuer2)
1 (S.L.bus_dooraft_sw)
1 (S.L.bremse_halte_sw)

(L.L.bus_dooraft_sw)
{if}
  (T.L.ev_VDV_on)
{else}
  (T.L.ev_VDV_off)
{endif}
{end}


(L.L.Autoschalter_Leasing_sw) ! (S.L.Autoschalter_Leasing_sw)	

	(L.L.Autoschalter_Leasing_sw)
	{if}
		(T.L.ev_VDV_on)
	{else}
		(T.L.ev_VDV_off)
	{endif}

(L.L.Autoschalter_Leasing_sw) 1 =
{if}
1 (S.L.Autoschalter_Tuer1)
{endif}

(L.L.Autoschalter_Leasing_sw) 1 =
{if}
1 (S.L.Autoschalter_Tuer2)
{endif}

(L.L.Autoschalter_Leasing_sw) 1 =
{if}
1 (S.L.bus_dooraft_sw)
{endif}

(L.L.Autoschalter_Leasing_sw) 0 =
{if}
0 (S.L.bus_dooraft_sw)
{endif}

{end}

{trigger:Tuerfreigabe_off}
0 (S.L.Autoschalter_Tuer1) (S.L.Autoschalter_Tuer2)
{end}


' Normalne zwolnienie drzwi (3 drzwi)

{trigger:bus_dooraft_down}
    1 (S.L.dooraft_pressed)

    (L.L.bus_dooraft_sw) -0.5 <
    {if}
        0 (S.L.bus_dooraft_sw)

		1 (S.L.close_lock01)
		1 (S.L.close_lock23)
		1 (S.L.close_lock45)
		1 (S.L.close_lock67)

        0 (S.L.bremse_halte_sw)
        0 (S.L.Autoschalter_Tuer1) (S.L.Autoschalter_Tuer2)
        0 (S.L.Tuerfreigabe_Tueroefner)
        (T.L.Tuerfreigabe_off)
        (T.L.ev_VDV_off)

        (L.L.bus_doorall_sw) 0 =
		{if}
			0 (S.L.doorTarget_01_delayed)
			0 (S.L.doorTarget_23_delayed)

			10 (S.L.doorAftLastOpen) (S.L.doorAftLastOpen1)

			(M.L.CloseGuard_01) !
			{if}
				(L.L.door_0) 0.05 >
				(L.L.door_1) 0.05 > ||
				{if}
					(C.L.tuerverzoegerung) 0 >
					{if}
						1 (S.L.close_lock01)
						1 (S.L.trigger_antirepeat01)
						0 (S.L.doortimer01)
					{else}
						1 (S.L.close_lock01)
						(M.L.doorwarn_01)

						(L.L.doorTarget_0) 1 =
						(L.L.door_0) 0.05 > &&
						{if}
							0 (S.L.doorTarget_0)
							(T.L.ev_doortriggerclose_0)
						{endif}

						(L.L.doorTarget_1) 1 =
						(L.L.door_1) 0.05 > &&
						{if}
							0 (S.L.doorTarget_1)
							(T.L.ev_doortriggerclose_1)
						{endif}
					{endif}
				{endif}
			{endif}

			(M.L.CloseGuard_23) !
			{if}
				1 (S.L.close_lock23)
				0 (S.L.doorTarget_23_delayed)
				0 (S.L.doortimer23)
				0 (S.L.trigger_antirepeat23)
			{endif}

			(M.L.CloseGuard_45) !
			{if}
				1 (S.L.close_lock45)
				1 (S.L.trigger_antirepeat45)
				0 (S.L.doortimer45)
			{endif}

			(M.L.CloseGuard_67) !
			{if}
				1 (S.L.close_lock67)
				1 (S.L.trigger_antirepeat67)
				0 (S.L.doortimer67)
			{endif}
		{endif}

        (L.L.door_handsteuerung)
        (L.L.bus_dooraft_sw) ! &&
        (L.L.bus_doorall_sw) ! &&
        {if}
            0 (S.L.door_handsteuerung)
            10 (S.L.doorAftLastOpen) (S.L.doorAftLastOpen1)
        {endif}

        (L.L.Door3_Error_Count) 1 + (S.L.Door3_Error_Count)

    {else}
        (L.L.bus_dooraft_sw) 0.5 >
        {if}
        {else}
            1 (S.L.bus_dooraft_sw)

            1 (S.L.bremse_halte_sw)
            1 (S.L.Autoschalter_Tuer1) (S.L.Autoschalter_Tuer2)
            1 (S.L.Tuerfreigabe_Tueroefner)
            (T.L.Tuerfreigabe)
            (T.L.ev_VDV_on)

            (L.L.door_handsteuerung)
            (L.L.bus_dooraft_sw) ! &&
            (L.L.bus_doorall_sw) ! &&
            {if}
                0 (S.L.door_handsteuerung)
                10 (S.L.doorAftLastOpen) (S.L.doorAftLastOpen1)
            {endif}

            (L.L.Door3_Error_Count) 1 + (S.L.Door3_Error_Count)
        {endif}
    {endif}
{end}

{trigger:bus_dooraft_down_off}
    0 (S.L.dooraft_pressed)
{end}

{trigger:bus_dooraft_up}
    -1 (S.L.dooraft_pressed)

    (L.L.bus_dooraft_sw) 0.5 >
    {if}
        0 (S.L.bus_dooraft_sw)

		1 (S.L.close_lock01)
		1 (S.L.close_lock23)
		1 (S.L.close_lock45)
		1 (S.L.close_lock67)

        0 (S.L.bremse_halte_sw)
        0 (S.L.Autoschalter_Tuer1) (S.L.Autoschalter_Tuer2)
        0 (S.L.Tuerfreigabe_Tueroefner)
        (T.L.Tuerfreigabe_off)
        (T.L.ev_VDV_off)

        (L.L.bus_doorall_sw) 0 =
		{if}
			0 (S.L.doorTarget_01_delayed)
			0 (S.L.doorTarget_23_delayed)

			10 (S.L.doorAftLastOpen) (S.L.doorAftLastOpen1)

			(M.L.CloseGuard_01) !
			{if}
				(L.L.door_0) 0.05 >
				(L.L.door_1) 0.05 > ||
				{if}
					(C.L.tuerverzoegerung) 0 >
					{if}
						1 (S.L.close_lock01)
						1 (S.L.trigger_antirepeat01)
						0 (S.L.doortimer01)
					{else}
						1 (S.L.close_lock01)
						(M.L.doorwarn_01)

						(L.L.doorTarget_0) 1 =
						(L.L.door_0) 0.05 > &&
						{if}
							0 (S.L.doorTarget_0)
							(T.L.ev_doortriggerclose_0)
						{endif}

						(L.L.doorTarget_1) 1 =
						(L.L.door_1) 0.05 > &&
						{if}
							0 (S.L.doorTarget_1)
							(T.L.ev_doortriggerclose_1)
						{endif}
					{endif}
				{endif}
			{endif}

			(M.L.CloseGuard_23) !
			{if}
				1 (S.L.close_lock23)
				0 (S.L.doorTarget_23_delayed)
				0 (S.L.doortimer23)
				0 (S.L.trigger_antirepeat23)
			{endif}

			(M.L.CloseGuard_45) !
			{if}
				1 (S.L.close_lock45)
				1 (S.L.trigger_antirepeat45)
				0 (S.L.doortimer45)
			{endif}

			(M.L.CloseGuard_67) !
			{if}
				1 (S.L.close_lock67)
				1 (S.L.trigger_antirepeat67)
				0 (S.L.doortimer67)
			{endif}
		{endif}

        (L.L.door_handsteuerung)
        (L.L.bus_dooraft_sw) ! &&
        (L.L.bus_doorall_sw) ! &&
        {if}
            0 (S.L.door_handsteuerung)
            10 (S.L.doorAftLastOpen) (S.L.doorAftLastOpen1)
        {endif}

        (L.L.Door3_Error_Count) 1 + (S.L.Door3_Error_Count)

    {else}
        (L.L.bus_dooraft_sw) -0.5 <
        {if}
        {else}
            -1 (S.L.bus_dooraft_sw)

            1 (S.L.bremse_halte_sw)
            1 (S.L.Autoschalter_Tuer1) (S.L.Autoschalter_Tuer2)
            1 (S.L.Tuerfreigabe_Tueroefner)
            (T.L.Tuerfreigabe)
            (T.L.ev_VDV_on)

            (L.L.door_handsteuerung)
            (L.L.bus_dooraft_sw) ! &&
            (L.L.bus_doorall_sw) ! &&
            {if}
                0 (S.L.door_handsteuerung)
                10 (S.L.doorAftLastOpen) (S.L.doorAftLastOpen1)
            {endif}

            (L.L.Door3_Error_Count) 1 + (S.L.Door3_Error_Count)
        {endif}
    {endif}
{end}

{trigger:bus_dooraft_up_off}
    0 (S.L.dooraft_pressed)
{end}

' Hamulec przystankowy
{trigger:bus_20h-switch}

(L.L.door_20h_sw) ! (S.L.door_20h_sw)
(L.L.hst_bremse_sw) ! (S.L.hst_bremse_sw)

	(L.L.hst_bremse_sw)
	{if}
		(T.L.ev_VDV_on)
	{else}
		(T.L.ev_VDV_off)
	{endif}
{end}

{trigger:bus_doorall_down}
    1 (S.L.bus_doorall)
    1 (S.L.doorall_pressed)
    0 (S.L.bus_doorall_sw)
    (T.L.ev_VDV_toggle_on)

	0 (S.L.close_lock01) (S.L.close_lock23) (S.L.close_lock45) (S.L.close_lock67)

    (L.L.velocity) 0.1 <
    (L.L.velocity) -0.1 > &&
    {if}

        (L.L.tuersperre) 0 =
        {if}
            (L.L.doorTarget_0) 0 =
            {if}
                1 (S.L.doorTarget_0)
                (T.L.ev_doortriggeropen_0)
            {endif}

            (L.L.doorTarget_1) 0 =
            {if}
                1 (S.L.doorTarget_1)
                (T.L.ev_doortriggeropen_1)
            {endif}
        {endif}

        (L.L.tuersperre) 0 <
        {if}
            (L.L.doorTarget_1) 0 =
            {if}
                1 (S.L.doorTarget_1)
                (T.L.ev_doortriggeropen_1)
            {endif}
        {endif}

        (L.L.tuersperre) 0 >
        {if}
            (L.L.doorTarget_0) 0 =
            {if}
                1 (S.L.doorTarget_0)
                (T.L.ev_doortriggeropen_0)
            {endif}
        {endif}

        (L.L.doorTarget_23_delayed) 0 =
        {if}
            1 (S.L.doorTarget_23) (S.L.doorTarget_23_delayed)
            (L.L.Tuer2_IST_SST) 0 =
            {if}  (T.L.ev_doortriggeropen_2)
            {else} (T.L.ev_doortriggeropen_2_SST)
            {endif}
        {endif}

        (L.L.doorTarget_45) 0 =
        {if}
            1 (S.L.doorTarget_45)
            (L.L.Tuer3_IST_SST) 0 =
            {if}  (T.L.ev_doortriggeropen_5)
            {else} (T.L.ev_doortriggeropen_5_SST)
            {endif}
            0 (S.L.doortimer45)
        {endif}

        (L.L.doorTarget_67) 0 =
        {if}
            1 (S.L.doorTarget_67)
            (L.L.Tuer4_IST_SST) 0 =
            {if}  (T.L.ev_doortriggeropen_7)
            {else} (T.L.ev_doortriggeropen_7_SST)
            {endif}
            0 (S.L.doortimer67)
        {endif}

        0 (S.L.doorAftLastOpen1)
    {endif}
{end}

{trigger:bus_doorall_down_off}
    0 (S.L.bus_doorall)
    0 (S.L.doorall_pressed)
    0 (S.L.bus_doorall_sw)
    (T.L.ev_VDV_toggle_off)
{end}

