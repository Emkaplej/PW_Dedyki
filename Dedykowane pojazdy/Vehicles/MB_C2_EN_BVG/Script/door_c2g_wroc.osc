	{if}
		(T.L.ev_nothahn45_auf)
		1 (S.L.doorTarget_45) (S.L.bremse_halte)
		5 random 10 / 0.5 + (S.L.door_4_soll)
		5 random 10 / 0.5 + (S.L.door_5_soll)
		1 (S.L.door_45_nothahn_sw)
	{endif}
{endif}
{end}

