	-1 (S.L.tuersperre) (S.L.tuersperre_sw)
	(T.L.ev_VDV_on)
		(L.L.door_0) 0 >
		{if}
		1 (S.L.doorTarget_1)
		(T.L.ev_doortriggeropen_0)
		{endif}
	{endif}
	(L.L.tuersperre) 1 =
	{if}
	0 (S.L.tuersperre) (S.L.tuersperre_sw)
	(T.L.ev_VDV_off)
	{endif}
{end}

{trigger:cp_tuersperre_down}	
	(L.L.tuersperre) 0 =
	{if}
	1 (S.L.tuersperre) (S.L.tuersperre_sw)
	(T.L.ev_VDV_on)
		(L.L.door_1) 0 >
