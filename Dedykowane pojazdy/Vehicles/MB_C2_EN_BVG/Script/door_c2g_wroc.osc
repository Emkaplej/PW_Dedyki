	1 (S.L.nothahn_67_dreh)

(L.L.Nothahn_aussen_gesperrt) 0 =
{if}
	(L.L.door_67_nothahn_sw) 0 =
	{if}
		(T.L.ev_nothahn67_auf)
		1 (S.L.doorTarget_67) (S.L.bremse_halte)
		5 random 10 / 0.5 + (S.L.door_6_soll)
		5 random 10 / 0.5 + (S.L.door_7_soll)
		1 (S.L.door_67_nothahn_sw)
	{endif}
{endif}
