{macro:SIL2_GetTime}


	(L.S.Time) 3600 / s0 trunc s1 "02" $IntToStrEnh ":" $+
	l0 l1 - 60 * s1 trunc s2 "02" $IntToStrEnh $+
	(S.$.GodzinaSIL2)
	
	(L.S.Time) 3600 / s0 trunc s1 "02" $IntToStrEnh ":" $+
	l0 l1 - 60 * s1 trunc s2 "02" $IntToStrEnh $+ ":" $+
	l1 l2 - 60 * trunc "02" $IntToStrEnh $+
	(S.$.GodzinaSIL2_sama)
	

{end}

{macro:SIL2_GetDate}

	"" "" $+ (L.S.Day) "02" $IntToStrEnh $+ " " $+ (L.$.nazwa_miesiaca) $+ " " $+ (L.S.Year) $IntToStr $+ (S.$.DataSIL2)
	
	(L.S.Month) "02" $IntToStrEnh (S.$.nr_miesiaca)
	
	(L.$.nr_miesiaca) "01" $=
	{if}
		"stycznia" (S.$.nazwa_miesiaca)
	{endif}
	
	(L.$.nr_miesiaca) "02" $=
	{if}
		"lutego" (S.$.nazwa_miesiaca)
	{endif}
	
	(L.$.nr_miesiaca) "03" $=
	{if}
		"marca" (S.$.nazwa_miesiaca)
	{endif}
	
	(L.$.nr_miesiaca) "04" $=
	{if}
		"kwietnia" (S.$.nazwa_miesiaca)
	{endif}
	
	(L.$.nr_miesiaca) "05" $=
	{if}
		"maja" (S.$.nazwa_miesiaca)
	{endif}
	
	(L.$.nr_miesiaca) "06" $=
	{if}
		"czerwca" (S.$.nazwa_miesiaca)
	{endif}
	
	(L.$.nr_miesiaca) "07" $=
	{if}
		"lipca" (S.$.nazwa_miesiaca)
	{endif}
	
	(L.$.nr_miesiaca) "08" $=
	{if}
		"sierpnia" (S.$.nazwa_miesiaca)
	{endif}
	
	(L.$.nr_miesiaca) "09" $=
	{if}
		"wrzeœnia" (S.$.nazwa_miesiaca)
	{endif}
	
	(L.$.nr_miesiaca) "10" $=
	{if}
		"paŸdziernika" (S.$.nazwa_miesiaca)
	{endif}
	
	(L.$.nr_miesiaca) "11" $=
