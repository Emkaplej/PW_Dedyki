		101 (S.L.5000_displaymode)
	{endif}
	
	(L.L.5000_displaymode) 302 =
	{if}
		"SIL2\SIL2_ekran_czy_przerwac_kurs.jpg" (S.$.SIL2_display_okienko)
		1 (S.L.SIL2_display_okienko_var)
	{endif}
	
	(L.L.5000_displaymode) 401 =
	{if}
		"" (S.$.Matrix_LiniaSpec)
		"" (S.$.Matrix_KierunekL1)
		"" (S.$.Matrix_KierunekL2)
		400 (S.L.5000_displaymode)
		0 (S.L.IBIS_Linie_Complex)
		-999 (S.L.Matrix_Nr_Last)
		-999 (S.L.Matrix_TerminusIndex_Last)
	{endif}
{end}

