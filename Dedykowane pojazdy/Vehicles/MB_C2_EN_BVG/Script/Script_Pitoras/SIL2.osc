{macro:IBIS_frame}

'	(S.L.Refresh_Strings)
	
	(L.L.elec_busbar_main)
	{if}
		1 (S.L.FIS_sterownik_wlaczony)
		(L.L.5000_kasowniki) 1 =
		{if}
			1 (S.L.FIS_zablokowane_kasowniki)
		{else}
			0 (S.L.FIS_zablokowane_kasowniki)
		{endif}

		(L.L.5000_displaymode) 302 =
		{if}
			1 (S.L.FIS_zalogowany_kierunek)
		{else}
			0 (S.L.FIS_zalogowany_kierunek)
		{endif}

		(L.L.5000_displaymode) 302 =
		{if}
			
			1 (S.L.FIS_zalogowany_z_trasa)

			(L.L.door_0) 0 >
			(L.L.door_1) 0 > ||
			(L.L.door_2) 0 > ||
			(L.L.door_3) 0 > ||
			(L.L.door_4) 0 > ||
			(L.L.door_5) 0 > ||
			(L.L.door_6) 0 > ||
			(L.L.door_7) 0 > ||
			{if}
				1 (S.L.FIS_zalogowany_na_przystanku)
			{else}
				0 (S.L.FIS_zalogowany_na_przystanku)
			{endif}

		{else}
			0 (S.L.FIS_zalogowany_z_trasa)
			0 (S.L.FIS_zalogowany_na_przystanku)
		{endif}
		
'************Uruchamianie************

		(L.L.uruchamianie) (L.S.Timegap) + (S.L.uruchamianie)
		
		(L.L.uruchamianie) 2 >=
		{if}
			(L.L.5000_displaymode) 0 =
			{if}
				1 (S.L.5000_displaymode)
				0 (S.L.uruchamianie)
			{endif}
		{endif}
		(L.L.uruchamianie) 2 >=
		{if}
			(L.L.5000_displaymode) 1 =
			{if}
				2 (S.L.5000_displaymode)
				0 (S.L.uruchamianie)
			{endif}
		{endif}
		(L.L.uruchamianie) 0.5 >=
		{if}	
			(L.L.5000_displaymode) 2 =
			{if}
				3 (S.L.5000_displaymode)
				0 (S.L.uruchamianie)
			{endif}
		{endif}
		(L.L.uruchamianie) 0.5 >=
		{if}	
			(L.L.5000_displaymode) 3 =
			{if}
				4 (S.L.5000_displaymode)
				0 (S.L.uruchamianie)
			{endif}
		{endif}
		(L.L.uruchamianie) 0.5 >=
		{if}	
			(L.L.5000_displaymode) 4 =
			{if}
				5 (S.L.5000_displaymode)
				0 (S.L.uruchamianie)
			{endif}
		{endif}
		(L.L.uruchamianie) 0.5 >=
		{if}	
			(L.L.5000_displaymode) 5 =
			{if}
				6 (S.L.5000_displaymode)
				0 (S.L.uruchamianie)
			{endif}
		{endif}
		(L.L.uruchamianie) 2 >=
		{if}	
			(L.L.5000_displaymode) 6 =
			{if}
				7 (S.L.5000_displaymode)
				0 (S.L.uruchamianie)
			{endif}
		{endif}
		(L.L.uruchamianie) 1 >=
		{if}	
			(L.L.5000_displaymode) 7 =
			{if}
				8 (S.L.5000_displaymode)
				0 (S.L.uruchamianie)
			{endif}
		{endif}
		(L.L.uruchamianie) 1 >=
		{if}	
			(L.L.5000_displaymode) 8 =
			{if}
				9 (S.L.5000_displaymode)
				0 (S.L.uruchamianie)
			{endif}
		{endif}
		(L.L.uruchamianie) 0.5 >=
		{if}	
			(L.L.5000_displaymode) 9 =
			{if}
				10 (S.L.5000_displaymode)
				0 (S.L.uruchamianie)
			{endif}
		{endif}
		(L.L.uruchamianie) 2 >=
		{if}	
			(L.L.5000_displaymode) 10 =
			{if}
				11 (S.L.5000_displaymode)
				0 (S.L.uruchamianie)
			{endif}
		{endif}
		(L.L.uruchamianie) 2 >=
		{if}	
			(L.L.5000_displaymode) 11 =
			{if}
				12 (S.L.5000_displaymode)
				0 (S.L.uruchamianie)
				(M.L.SIMS_startup_sound)
			{endif}
		{endif}
		(L.L.uruchamianie) 1 >=
		{if}	
			(L.L.5000_displaymode) 12 =
			{if}
				13 (S.L.5000_displaymode)
				0 (S.L.uruchamianie)
			{endif}
		{endif}
		(L.L.uruchamianie) 0.5 >=
		{if}	
			(L.L.5000_displaymode) 13 =
			{if}
				14 (S.L.5000_displaymode)
				0 (S.L.uruchamianie)
			{endif}
		{endif}
		(L.L.uruchamianie) 1 >=
		{if}	
			(L.L.5000_displaymode) 14 =
			{if}
				101 (S.L.5000_displaymode)
				0 (S.L.uruchamianie)
				1 (S.L.SIL2_wlaczony)
			{endif}	
		{endif}
		
'************Makro wyciagania czasu************
		
			(M.L.SIL2_GetDate)
			(M.L.SIL2_GetTime)
		
'************Kiedy ma byc szukanie linii i wariantow************

		(L.L.5000_displaymode) 300 =
		(L.L.5000_displaymode) 301 = ||
		{if}
			(M.L.skan_linii)
		{endif}
		
'************Pierdolnik do wy˜wietlania op˜nienia xD************
		
	(L.L.schedule_active) 1 =
	{if}
		
		
		
		
		
		
'		(L.L.IBIS_busstop) (M.V.GetTTBusstopDep) (L.S.Time) - 60 / trunc abs $IntToStr (S.$.ITeeF_WYKURWISTE_MINUTY)
		
		(L.L.IBIS_busstop) (M.V.GetTTBusstopDep) (L.S.Time) - 60 / (S.L.minuty_z_przecinkiem)
		(L.L.minuty_z_przecinkiem) trunc (S.L.minuty_bez_przecinka)		
		(L.L.minuty_z_przecinkiem) (L.L.minuty_bez_przecinka) - 60 * trunc abs "02" $IntToStrEnh (S.$.ITF_SEKUNDY_CHUJOWE)
		
		(L.L.minuty_z_przecinkiem) 60 / trunc abs (S.L.godziny_jakies)
		
		(L.L.IBIS_busstop) (M.V.GetTTBusstopDep) (L.S.Time) - 60 / trunc abs (S.L.minuty_do_konwersji)
		
		(L.L.godziny_jakies) 0 =
		{if}
			(L.L.minuty_do_konwersji) $IntToStr (S.$.ITeeF_WYKURWISTE_MINUTY)
			(L.L.godziny_jakies) $IntToStr (S.$.ITeeF_FAJNE_GODZINY)
			"0" (L.$.ITeeF_FAJNE_GODZINY) $+ (S.$.ITeeF_FAJNE_GODZINY)
		{endif}
		
		(L.L.godziny_jakies) 1 =
		{if}
			(L.L.minuty_do_konwersji) 60 - $IntToStr (S.$.ITeeF_WYKURWISTE_MINUTY)
			(L.L.godziny_jakies) $IntToStr (S.$.ITeeF_FAJNE_GODZINY)
			"0" (L.$.ITeeF_FAJNE_GODZINY) $+ (S.$.ITeeF_FAJNE_GODZINY)
		{endif}
		
		(L.L.godziny_jakies) 2 =
		{if}
			(L.L.minuty_do_konwersji) 120 - $IntToStr (S.$.ITeeF_WYKURWISTE_MINUTY)
			(L.L.godziny_jakies) $IntToStr (S.$.ITeeF_FAJNE_GODZINY)
			"0" (L.$.ITeeF_FAJNE_GODZINY) $+ (S.$.ITeeF_FAJNE_GODZINY)
		{endif}

		(L.L.godziny_jakies) 3 =
		{if}
			(L.L.minuty_do_konwersji) 180 - $IntToStr (S.$.ITeeF_WYKURWISTE_MINUTY)
