				(L.L.nrLinii_skan) (S.L.Linia_Linijka0Int)
			{endif}
			(L.L.nrIndex_linii) 1 =
			{if}
				(L.L.nrLinii_skan) $IntToStr (S.$.Linia_Linijka1)
				(L.L.nrLinii_skan) (S.L.Linia_Linijka1Int)
			{endif}
			(L.L.nrIndex_linii) 2 =
			{if}
				(L.L.nrLinii_skan) $IntToStr (S.$.Linia_Linijka2)
				(L.L.nrLinii_skan) (S.L.Linia_Linijka2Int)
			{endif}
			(L.L.nrIndex_linii) 3 =
			{if}
				(L.L.nrLinii_skan) $IntToStr (S.$.Linia_Linijka3)
				(L.L.nrLinii_skan) (S.L.Linia_Linijka3Int)
			{endif}
			(L.L.nrIndex_linii) 4 =
			{if}
				(L.L.nrLinii_skan) $IntToStr (S.$.Linia_Linijka4)
				(L.L.nrLinii_skan) (S.L.Linia_Linijka4Int)
			{endif}
			(L.L.nrIndex_linii) 5 =
			{if}
				(L.L.nrLinii_skan) $IntToStr (S.$.Linia_Linijka5)
				(L.L.nrLinii_skan) (S.L.Linia_Linijka5Int)
			{endif}
			(L.L.nrIndex_linii) 6 =
			{if}
				(L.L.nrLinii_skan) $IntToStr (S.$.Linia_Linijka6)
				(L.L.nrLinii_skan) (S.L.Linia_Linijka6Int)
				0 (S.L.skan_aktywny)
				0 (S.L.SIL2_display_okienko_var)
			{endif}

			(L.L.nrIndex_linii) 1 + (S.L.nrIndex_linii)
			
		{endif}
		
		(L.L.nrLinii_skan) 1 + (S.L.nrLinii_skan)
		(L.L.nrLinii_skan) 1000 >=
		{if}
			0 (S.L.skan_aktywny)
			0 (S.L.SIL2_display_okienko_var)
		{endif}
		
{endif}

(L.L.skan_wariantow_aktywny) 1 =
{if}
		1 (S.L.SIL2_display_okienko_var)
		"SIL2\SIL2_ekran_ladowanie_linii.jpg" (S.$.SIL2_display_okienko)
		
		(L.L.IBIS_LinieKurs) 100 * (L.L.IBIS_Route_cos2137) + (M.V.GetRouteIndex) s1
		0 <
		{if}

		{else}
			(L.L.nrIndex_wariantu) 0 =
			{if}
				l1 (M.V.GetRouteTerminusIndex) 5 (M.V.GetTerminusString) (S.$.Linia_Linijka0)
				(L.L.IBIS_Route_cos2137) $IntToStr ". " $+ (L.$.Linia_Linijka0) $+ (S.$.Linia_Linijka0)

				(L.L.IBIS_Route_cos2137) (S.L.Wariant_Linijka0IntRoute)
			{endif}
			(L.L.nrIndex_wariantu) 1 =
			{if}
				l1 (M.V.GetRouteTerminusIndex) 5 (M.V.GetTerminusString) (S.$.Linia_Linijka1)
				(L.L.IBIS_Route_cos2137) $IntToStr ". " $+ (L.$.Linia_Linijka1) $+ (S.$.Linia_Linijka1)

				(L.L.IBIS_Route_cos2137) (S.L.Wariant_Linijka1IntRoute)

			{endif}
			(L.L.nrIndex_wariantu) 2 =
			{if}
				l1 (M.V.GetRouteTerminusIndex) 5 (M.V.GetTerminusString) (S.$.Linia_Linijka2)
				(L.L.IBIS_Route_cos2137) $IntToStr ". " $+ (L.$.Linia_Linijka2) $+ (S.$.Linia_Linijka2)

				(L.L.IBIS_Route_cos2137) (S.L.Wariant_Linijka2IntRoute)
			{endif}
			(L.L.nrIndex_wariantu) 3 =
			{if}
				l1 (M.V.GetRouteTerminusIndex) 5 (M.V.GetTerminusString) (S.$.Linia_Linijka3)
				(L.L.IBIS_Route_cos2137) $IntToStr ". " $+ (L.$.Linia_Linijka3) $+ (S.$.Linia_Linijka3)

				(L.L.IBIS_Route_cos2137) (S.L.Wariant_Linijka3IntRoute)
			{endif}
			(L.L.nrIndex_wariantu) 4 =
			{if}
				l1 (M.V.GetRouteTerminusIndex) 5 (M.V.GetTerminusString) (S.$.Linia_Linijka4)
				(L.L.IBIS_Route_cos2137) $IntToStr ". " $+ (L.$.Linia_Linijka4) $+ (S.$.Linia_Linijka4)

				(L.L.IBIS_Route_cos2137) (S.L.Wariant_Linijka4IntRoute)
			{endif}
			(L.L.nrIndex_wariantu) 5 =
			{if}
				l1 (M.V.GetRouteTerminusIndex) 5 (M.V.GetTerminusString) (S.$.Linia_Linijka5)
				(L.L.IBIS_Route_cos2137) $IntToStr ". " $+ (L.$.Linia_Linijka5) $+ (S.$.Linia_Linijka5)

				(L.L.IBIS_Route_cos2137) (S.L.Wariant_Linijka5IntRoute)
			{endif}
			(L.L.nrIndex_wariantu) 6 =
			{if}
				l1 (M.V.GetRouteTerminusIndex) 5 (M.V.GetTerminusString) (S.$.Linia_Linijka6)
				(L.L.IBIS_Route_cos2137) $IntToStr ". " $+ (L.$.Linia_Linijka6) $+ (S.$.Linia_Linijka6)

				(L.L.IBIS_Route_cos2137) (S.L.Wariant_Linijka6IntRoute)
				0 (S.L.skan_wariantow_aktywny)
				0 (S.L.SIL2_display_okienko_var)
			{endif}

			(L.L.nrIndex_wariantu) 1 + (S.L.nrIndex_wariantu)
		{endif}
		
		(L.L.IBIS_Route_cos2137) 1 + (S.L.IBIS_Route_cos2137)
		(L.L.IBIS_Route_cos2137) 99 >=
		{if}
			0 (S.L.skan_wariantow_aktywny)
			0 (S.L.SIL2_display_okienko_var)
		{endif}	
		
{endif}

{end}

{macro:wybor_trasy}
	(L.L.IBIS_inputWariant) s0 (S.L.IBIS_Route)
	(L.L.IBIS_LinieKurs) 100 * l0 + (M.V.GetRouteIndex) s1
	0 <
	{if}

			101 (S.L.5000_displaymode)
			0 (S.L.IBIS_Linie_Complex)
'			1 (S.L.liniabrygada)
	{else}
		(M.L.IBIS_RefreshBusstop)
		(M.L.IBIS_SetRoute)
		0 (S.L.liniabrygada)
		0 (S.L.IBIS_busstop)
		(M.L.IBIS_RefreshBusstop)
		0 (S.L.bylo_rozpoczecie)
		0 (S.L.RK_Timerek)
	{endif}
{end}

{macro:IBIS_RefreshBusstop}

	(L.L.IBIS_RouteIndex) 0 <
	{if}
		"" (S.$.act_busstop)
	{else}
	(L.L.IBIS_RouteIndex) (M.V.GetBusstopCount) (L.L.IBIS_busstop) <=
	{if}
'Wenn der Bushaltestellenindex gr˜˜er oder gleich der Anzahl ist und somit zu gro˜ (der Bushaltestellenindex ist wie alle Indizes nullbasiert), 
'dann wechsele automatisch auf die Gegenroute, sofern der Index 01 oder 02 ist und der jeweilige andere Index existiert. Sonst belasse die Route.
		0 (S.L.IBIS_busstop)
' Entwerter umstellen:
		(T.L.ev_IBIS_entwerter)
		(L.L.IBIS_busstop_entwerter_soll) (S.L.IBIS_busstop_entwerter_ist)

		(L.L.IBIS_Route) s5
		1.5 <
		{if}
			2 s6
		{else}
			l5 2.5 <
			{if}
				1 s6
			{endif}
		{endif}

'Suche den Routeindex:

		(L.L.IBIS_LinieKurs) 100 * l6 + (M.V.GetRouteIndex) s1
		0 >=
		{if}
'Wenn g˜ltig, dann wechsele:
			(M.L.IBIS_SetRoute)
			l6 (S.L.IBIS_Route)
'(M.L.Fahrscheindrucker-Haltestelle)
		{endif}
	{else}
		0 (S.L.IBIS_mode)
	{endif}
	{endif}

'Setzen der String-Variable "act_busstop" f˜r die OMSI-interne Berechnung und daraus Ableitung des "globalen" Haltestellenindexes:

	(L.L.IBIS_RouteIndex) (L.L.IBIS_busstop) (M.V.GetRouteBusstopIdent) (S.$.act_busstop)
	(M.V.GetBusstopIndex) (S.L.IBIS_busstop_index)


'Sonst zeige die Bushaltestelle
	(L.L.IBIS_busstop_index) 3 (M.V.GetBusstopString)
	(S.$.IBIS_busstop_name)

'Ausrechnen der neuen Entwerterposition:
	(L.L.IBIS_busstop_offset) (L.L.IBIS_busstop) + (S.L.IBIS_busstop_entwerter_soll)


{end}

{macro:IBIS_SetRoute}

' Macro setzt den Routeindex auf den Wert von l1 und f˜hrt die n˜tigen Schritte aus

' Wenn g˜ltig, dann ˜bernehmen:
	l1 (S.L.IBIS_RouteIndex)
' Finden des zugeh˜rigen Ziel-Index':
	(M.V.GetRouteTerminusIndex) (S.L.IBIS_TerminusIndex)
' Finden des zugeh˜rigen Ziel-Codes:
	(M.V.GetTerminusCode) (S.L.IBIS_TerminusCode)
	
' Aktualisieren des Zielschild-Textes:
	(M.L.IBIS_RefreshTerminusText)
' Ziel anzeigen:
	0 (S.L.IBIS_modetimer)
	8 (S.L.IBIS_mode)

' Falls es entweder ein 500, ein 800 oder 900-Code ist, dann bitte beim Complex-Code eine 28 (M), eine 36 (X) bzw. 04 (N) verwenden:
	(L.L.IBIS_LinieKurs) s2 100 / trunc s3
	l3 5 =
	{if}
		l2 100 * 5 (M.V.GetDepotStringGlobal) $StrToFloat 0 max (S.L.IBIS_Linie_Suffix) + (S.L.IBIS_Linie_Complex)
	{endif}
	l3 8 =
	{if}
		l2 100 * 4 (M.V.GetDepotStringGlobal) $StrToFloat 0 max (S.L.IBIS_Linie_Suffix) + (S.L.IBIS_Linie_Complex)
	{endif}
	l3 9 =
	{if}
		l2 100 * 3 (M.V.GetDepotStringGlobal) $StrToFloat 0 max (S.L.IBIS_Linie_Suffix) + (S.L.IBIS_Linie_Complex)
	{endif}
'	(M.L.IBIS_SetComplexLineString)

' Entwerter-Busstop-Offset festlegen (pseudo-Zufall aus Linien-Code und Route-Index):

	(L.L.IBIS_LinieKurs) 100 * (L.L.IBIS_RouteIndex) + 10000 * sin 10 * 15 + trunc (S.L.IBIS_busstop_offset)

{end}

{macro:IBIS_RefreshTerminusText}
	(L.L.IBIS_TerminusIndex) 5 (M.V.GetTerminusString) (S.$.IBIS_terminus_name)
	(L.L.IBIS_TerminusIndex) (S.L.target_index_int)
{end}

{macro:polaryzacja_minut}
	
		(L.L.IBIS_busstop) (M.V.GetTTBusstopDep) (L.S.Time) <
		{if}
			"- " (S.$.ITF_NIE_WYPIERDALAJ_GUNWA_CHUJU)
		{else}
			"+ " (S.$.ITF_NIE_WYPIERDALAJ_GUNWA_CHUJU)
		{endif}
{end}

{macro:AktualnyPrzystanekZapowiedz}

	(L.L.IBIS_busstop) 0 >
	{if}

		"..\..\Announcements\" 0 (M.V.GetDepotStringGlobal) "\" $+ $+ (L.$.act_busstop) "_" $+ $+

		(L.L.IBIS_RouteIndex) (M.V.GetBusstopCount) 1 - (L.L.IBIS_busstop) <=
		{if}
			"_#terminus" $+
		{endif}

		".wav" $+
		(T.F.ev_IBIS_Ansagen)
	{endif}
{end}

{macro:IBIS_PlayAnnouncement}

	(L.L.IBIS_busstop) 0 >
	{if}

		"..\..\Announcements\" 0 (M.V.GetDepotStringGlobal) "\" $+ $+ (L.$.act_busstop) $+ $msg ".wav" $+

		$msg (T.F.ev_IBIS_Ansagen)
		(T.F.ev_IBIS_Ansagen)
	{endif}
{end}

{macro:ZewnetrznaZapowiedz}

	(L.L.IBIS_LinieKurs) 0 >
	{if}
		"..\..\Announcements\" 0 (M.V.GetDepotStringGlobal) "\" $+ $+ 
		(L.L.IBIS_LinieKurs) $IntToStr $+
		"-" $+ (L.L.IBIS_inputWariant) "02" $IntToStrEnh $+
		".wav" $+
		$msg
		(T.F.ev_IBIS_Ansagen)
	{endif}

{end}
