{trigger:parking_brake_toggle}
	(L.L.bremse_feststell) ! (S.L.bremse_feststell) (S.L.bremse_feststell_sw)
	{if}
		(T.L.ev_bremse_feststell_ein)
	{else}
		(T.L.ev_bremse_feststell_aus)
	{endif}
	(L.L.parkbrake_Error_Count) 1 + (S.L.parkbrake_Error_Count)
{end}


{trigger:parking_brake_set}
	(L.L.bremse_feststell) !
	{if}
		(S.L.bremse_feststell)
		(T.L.ev_bremse_feststell_ein)
		1 (S.L.bremse_feststell_sw)
	{endif}
	(L.L.parkbrake_Error_Count) 1 + (S.L.parkbrake_Error_Count)
{end}

{trigger:parking_brake_release}
	(L.L.bremse_feststell)
	{if}
		! (S.L.bremse_feststell)
		(T.L.ev_bremse_feststell_aus)
		0 (S.L.bremse_feststell_sw)
	{endif}
	(L.L.parkbrake_Error_Count) 1 + (S.L.parkbrake_Error_Count)
{end}

{trigger:parking_brake_mouse_drag}
	(L.S.mouse_y) 200 / (L.L.bremse_feststell_sw) + (S.L.bremse_feststell_sw) s0
	l0 0 <
	{if}
		0 (S.L.bremse_feststell_sw)
	{endif}
	l0 1 >
	{if}
		1 (S.L.bremse_feststell_sw)
	{endif}
	l0 0.6 > (L.L.bremse_feststell) 0 = &&
	{if}
		1 (S.L.bremse_feststell)
		(T.L.ev_bremse_feststell_ein)
		(L.L.parkbrake_Error_Count) 1 + (S.L.parkbrake_Error_Count)
	{endif}
	l0 0.4 < (L.L.bremse_feststell) 1 = &&
	{if}
		0 (S.L.bremse_feststell)
		(T.L.ev_bremse_feststell_aus)
		(L.L.parkbrake_Error_Count) 1 + (S.L.parkbrake_Error_Count)
	{endif}

	1 (S.L.bremse_feststell_klinke)
{end}

{trigger:parking_brake_mouse_off}
	0 (S.L.bremse_feststell_klinke)
{end}

{trigger:wagenkasten_anheben}

(L.L.elec_busbar_main)
{if}
1 (S.L.anheben_sw_rot_up)
{endif}

	1 (S.L.anheben_sw) (S.L.ecas_rise_active) (S.L.ecas_rise)
	(T.L.ev_VDV_toggle_on)
{end}

{trigger:wagenkasten_anheben_off}
	0 (S.L.anheben_sw) (S.L.ecas_rise) (S.L.ecas_rise_active) (S.L.anheben_sw_rot_up)
	(T.L.ev_VDV_toggle_off)
{end}

{trigger:wagenkasten_anheben_down}

(L.L.elec_busbar_main)
{if}
1 (S.L.anheben_sw_rot_down)
{endif}

	-1 (S.L.anheben_sw)
	0 (S.L.ecas_rise_active) (S.L.ecas_rise)
	1 (S.L.regelung_stand_timer)
	(T.L.ev_VDV_toggle_on)
{end}

{trigger:wagenkasten_anheben_down_off}
	0 (S.L.anheben_sw) (S.L.anheben_sw_rot_down)
	(T.L.ev_VDV_toggle_off)
{end}

{trigger:bus_kneel_auto}
	(L.L.kneel_auto_set) ! (S.L.kneel_auto_set)

	1 (S.L.bus_kneel_auto_anim)

	(L.L.kneel_auto_set) (S.L.taster_rot_kneeling)

	(T.L.ev_VDV_toggle_on)
{end}

{trigger:bus_kneel_auto_off}
	0 (S.L.bus_kneel_auto_anim)

	(T.L.ev_VDV_toggle_off)
{end}


'----------------------
'	Init
'----------------------

{macro:bremse_init}

    0 (S.L.retarder_off_light)

	10 random 10 / 0.55 max (S.L.Axle_Springfactor_0_L)
	10 random 10 / 0.55 max (S.L.Axle_Springfactor_0_R)
	10 random 10 / 0.55 max (S.L.Axle_Springfactor_1_L)
	10 random 10 / 0.55 max (S.L.Axle_Springfactor_1_R)

	(C.L.bremse_level_setpoint) (S.L.bremse_level_setpoint)
	1 (S.L.bremse_feststell_sw) (S.L.bremse_feststell) (S.L.bremse_UeVentil_1) (S.L.bremse_UeVentil_2) (S.L.sound_antirepeat_up)

	900000 random 900000 random + 300000 max 1000000 min (S.L.bremse_p_tank01) (S.L.bremse_p_leitung01) (S.L.bremse_p_leitung02) s0

	(C.L.bremse_UeVentil_1_schliessdruck) >
	{if}
		l0 (S.L.bremse_p_tank02)
	{else}
		600000 random 300000 max (S.L.bremse_p_tank02)
	{endif}

	900000 random 900000 random + 300000 max l0 min (S.L.bremse_p_tank03) s1

	(C.L.bremse_UeVentil_2_schliessdruck) >
	{if}
		l1 (S.L.bremse_p_tank04)
	{else}
		600000 random 300000 max (S.L.bremse_p_tank04) s0
	{endif}


'Setzen der Bremszylinderdr�cke	
	100000 (S.L.bremse_p_luft) (S.L.bremse_p_brzyl_VA) (S.L.bremse_p_brzyl_VA_R) (S.L.bremse_p_brzyl_VA_L) (S.L.bremse_p_brzyl_HA) (S.L.bremse_p_brzyl_HA_R) (S.L.bremse_p_brzyl_HA_L) (S.L.bremse_p_Brzyl_FBA) 


	0 (S.L.bremse_loesezischbereitschaft) (S.L.bremse_bremszischbereitschaft) (S.L.bremse_zieldruckdifferenz) 
	
	0 (L.L.bremse_loesezischzeit)
	
' Setzen des Initial-Hup/Quietschvolumes

	-2 (S.L.bremse_quietsch_volume)
0 (S.L.c2step3_Busvariante)
0 (S.L.kneel_auto_set) (S.L.bus_kneel_auto_anim) (S.L.taster_rot_kneeling)
(L.L.bus_dooraft_sw) (S.L.bus_dooraft_sw_last)
0 (S.L.kneel_allowed_timer)
0 (S.L.kneel_manual_active)
0 (S.L.anheben_sw_rot_up) (S.L.anheben_sw_rot_down)
{end}

